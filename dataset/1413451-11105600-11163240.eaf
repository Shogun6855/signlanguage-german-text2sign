PANT="ber-mod-1"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts72" TIME_SLOT_REF2="ts84" ANNOTATION_ID="a2943582"><ANNOTATION_VALUE>That means you grew up orally until you entered kindergarten.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts164" ANNOTATION_ID="a2943602"><ANNOTATION_VALUE>That’s where you learned it then?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts268" ANNOTATION_ID="a2943691"><ANNOTATION_VALUE>Who did you have the most contact with?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts338" ANNOTATION_ID="a2943777"><ANNOTATION_VALUE>Too bad. What do you think are advantages and disadvantages of being deaf?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts464" ANNOTATION_ID="a2943806"><ANNOTATION_VALUE>What do you think is an advantage?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts631" ANNOTATION_ID="a2943836"><ANNOTATION_VALUE>In the past, were your experiences positive or negative? What were your biggest problems?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts634" TIME_SLOT_REF2="ts636" ANNOTATION_ID="a2943837"><ANNOTATION_VALUE>Good or bad experiences, either way.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts868" TIME_SLOT_REF2="ts873" ANNOTATION_ID="a2949124"><ANNOTATION_VALUE>And what was it like during your time in Halberstadt?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts970" TIME_SLOT_REF2="ts997" ANNOTATION_ID="a2950707"><ANNOTATION_VALUE>For example in Essen? There were many/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1133" TIME_SLOT_REF2="ts1143" ANNOTATION_ID="a2950717"><ANNOTATION_VALUE>You started studying ASL in Essen, didn't you?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1189" TIME_SLOT_REF2="ts1191" ANNOTATION_ID="a2950720"><ANNOTATION_VALUE>Being in company makes you feel at ease.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1248" TIME_SLOT_REF2="ts1256" ANNOTATION_ID="a2950726"><ANNOTATION_VALUE>There was a lot to experience for you, wasn't it?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1259" TIME_SLOT_REF2="ts1264" ANNOTATION_ID="a2950727"><ANNOTATION_VALUE>Do you have any role models - somebody you look up to?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1272" TIME_SLOT_REF2="ts1282" ANNOTATION_ID="a2950729"><ANNOTATION_VALUE>I don't know; they are your role models.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1334" TIME_SLOT_REF2="ts1339" ANNOTATION_ID="a2950737"><ANNOTATION_VALUE>A deaf person?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1429" TIME_SLOT_REF2="ts1435" ANNOTATION_ID="a2950746"><ANNOTATION_VALUE>Does he live in Halberstadt?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1495" TIME_SLOT_REF2="ts1502" ANNOTATION_ID="a2950750"><ANNOTATION_VALUE>Are you keeping in touch?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1537" TIME_SLOT_REF2="ts1542" ANNOTATION_ID="a2950756"><ANNOTATION_VALUE>Does he still live in Frankfurt?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1562" TIME_SLOT_REF2="ts1566" ANNOTATION_ID="a2950758"><ANNOTATION_VALUE>What are your greatest memories?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__coarser_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_dependent_values" TIME_ALIGNABLE="false" CONSTRAINTS="Symbolic_Association"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_tokens_right_left__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__mouth__standard_orthography__coarser_granularity" TIME_ALIGNABLE="true"/><CONSTRAINT STEREOTYPE="Symbolic_Association" DESCRIPTION="1-1 association with a parent annotation"/></ANNOTATION_DOCUMENT>
