_ID="a2731864"><ANNOTATION_VALUE>achtzig</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2954" TIME_SLOT_REF2="ts2955" ANNOTATION_ID="a2397345"><ANNOTATION_VALUE>prozent</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2956" TIME_SLOT_REF2="ts2959" ANNOTATION_ID="a2397354"><ANNOTATION_VALUE>ausländer</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2960" TIME_SLOT_REF2="ts2961" ANNOTATION_ID="a2397374"><ANNOTATION_VALUE>deutsch</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2964" TIME_SLOT_REF2="ts2965" ANNOTATION_ID="a2401414"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2970" TIME_SLOT_REF2="ts2971" ANNOTATION_ID="a2401446"><ANNOTATION_VALUE>ausländ</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2972" TIME_SLOT_REF2="ts2977" ANNOTATION_ID="a2401447"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2978" TIME_SLOT_REF2="ts2979" ANNOTATION_ID="a2401449"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2980" TIME_SLOT_REF2="ts2981" ANNOTATION_ID="a2401493"><ANNOTATION_VALUE>so</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2982" TIME_SLOT_REF2="ts2983" ANNOTATION_ID="a2401461"><ANNOTATION_VALUE>früh</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2984" TIME_SLOT_REF2="ts2988" ANNOTATION_ID="a2401466"><ANNOTATION_VALUE>türken</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2991" TIME_SLOT_REF2="ts2993" ANNOTATION_ID="a2401463"><ANNOTATION_VALUE>früh</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_B" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="ber-13"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts16" ANNOTATION_ID="a2996978"><ANNOTATION_VALUE>Members of my family have been entirely deaf for four generations now.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts16" TIME_SLOT_REF2="ts20" ANNOTATION_ID="a2996981"><ANNOTATION_VALUE>I am part of the fifth generation.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts20" TIME_SLOT_REF2="ts49" ANNOTATION_ID="a2996991"><ANNOTATION_VALUE>I didn't grow up at a boarding school but commuted back and forth between my parents place and a school for the deaf.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts72" ANNOTATION_ID="a2996999"><ANNOTATION_VALUE>I started school when I was five.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts72" TIME_SLOT_REF2="ts89" ANNOTATION_ID="a2997004"><ANNOTATION_VALUE>I could sign already, but all the other children couldn’t.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts106" ANNOTATION_ID="a2997010"><ANNOTATION_VALUE>They came from the villages all around; they didn't know how to sign.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts143" ANNOTATION_ID="a2997019"><ANNOTATION_VALUE>I wasn't able to talk to them - that was frustrating. That's why I built up contact with older students, for example in grade three or four.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts158" ANNOTATION_ID="a2997020"><ANNOTATION_VALUE>On the one hand, it was good having contact to people and being able to talk to them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts158" TIME_SLOT_REF2="ts176" ANNOTATION_ID="a2997032"><ANNOTATION_VALUE>On the other hand, I was the one who got sent ahead to deal with different things for them. It was a lot to shoulder.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts176" TIME_SLOT_REF2="ts209" ANNOTATION_ID="a2997040"><ANNOTATION_VALUE>If I wanted to be friends with and protected by them, I had to endure quite a bit in return.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts225" ANNOTATION_ID="a2997045"><ANNOTATION_VALUE>Yes, I rather hung out with older children than with children of my age group.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts257" ANNOTATION_ID="a2997054"><ANNOTATION_VALUE>Time went by so fast: the older kids had left school already, and I attended grade nine by then.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts288" ANNOTATION_ID="a2997060"><ANNOTATION_VALUE>I was now only surrounded by kids of the same age and younger ones. Yet, they all weren't very good at signing.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts288" TIME_SLOT_REF2="ts306" ANNOTATION_ID="a2997101"><ANNOTATION_VALUE>That's why I drove to the training centers where I could meet and talk to deaf people I knew from before.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts306" TIME_SLOT_REF2="ts314" ANNOTATION_ID="a2997111"><ANNOTATION_VALUE>I guess the other students thought I felt better than them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts314" TIME_SLOT_REF2="ts321" ANNOTATION_ID="a2997126"><ANNOTATION_VALUE>Well, I didn't really care about them because I wasn't comfortable around them anyways.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts344" ANNOTATION_ID="a2997129"><ANNOTATION_VALUE>Then, my mother asked me what kind of job I would like to have.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts344" TIME_SLOT_REF2="ts364" ANNOTATION_ID="a2997130"><ANNOTATION_VALUE>My grades were really good.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts364" TIME_SLOT_REF2="ts376" ANNOTATION_ID="a2997133"><ANNOTATION_VALUE>My report cards were full of A’s back then.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts376" TIME_SLOT_REF2="ts396" ANNOTATION_ID="a2997145"><ANNOTATION_VALUE>At the time, we didn't have the ‘Realschule’ [type of secondary school] or any other kind of continuative educational opportunities for deaf students.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts396" TIME_SLOT_REF2="ts425" ANNOTATION_ID="a2997147"><ANNOTATION_VALUE>Even though I was far ahead of the other students, I was stuck with them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts445" ANNOTATION_ID="a2997151"><ANNOTATION_VALUE>My mother talked to the headmaster and asked him for a suggestion.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts464" ANNOTATION_ID="a2997156"><ANNOTATION_VALUE>He said I should try going to a school for the hard of hearing.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts464" TIME_SLOT_REF2="ts474" ANNOTATION_ID="a2997157"><ANNOTATION_VALUE>I liked that idea.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts474" TIME_SLOT_REF2="ts501" ANNOTATION_ID="a2997158"><ANNOTATION_VALUE>I told my mother, who's deaf as well, that I would love to go there.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts530" ANNOTATION_ID="a2997159"><ANNOTATION_VALUE>Yet, she rejected my proposal because she believed that the hard of hearing weren't at terms with themselves, and that this would lead to problems such as bullying.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts530" TIME_SLOT_REF2="ts539" ANNOTATION_ID="a2997161"><ANNOTATION_VALUE>My mother didn't want that.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts548" ANNOTATION_ID="a2997165"><ANNOTATION_VALUE>'You're better off with deaf people around. They are honest people.'</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts548" TIME_SLOT_REF2="ts561" ANNOTATION_ID="a2997166"><ANNOTATION_VALUE>My mother thought that the hard of hearing didn't really know where they belonged.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts569" ANNOTATION_ID="a2997167"><ANNOTATION_VALUE>That's why she didn't want me to go to a school for the hard of hearing.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts576" ANNOTATION_ID="a2997168"><ANNOTATION_VALUE>I was really disappointed, but I had to stay at the school for the deaf nonetheless.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts576" TIME_SLOT_REF2="ts592" ANNOTATION_ID="a2997185"><ANNOTATION_VALUE>I stayed there until I was done with school. I then started my apprenticeship.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts592" TIME_SLOT_REF2="ts610" ANNOTATION_ID="a2997191"><ANNOTATION_VALUE>You were forced to choose one out of ten occupations. There were no other options.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts610" TIME_SLOT_REF2="ts621" ANNOTATION_ID="a2997196"><ANNOTATION_VALUE>Like becoming a tailor, an upholsterer, or a carpenter.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts621" TIME_SLOT_REF2="ts630" ANNOTATION_ID="a2997197"><ANNOTATION_VALUE>I would have liked to learn something better, but it was impossible.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts630" TIME_SLOT_REF2="ts658" ANNOTATION_ID="a2997205"><ANNOTATION_VALUE>Back in the 70s, it just wasn't possible under the communist regime. There was nothing you could do about it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts658" TIME_SLOT_REF2="ts683" ANNOTATION_ID="a2997207"><ANNOTATION_VALUE>I had to choose one out of the ten occupations; I chose to try becoming an upholsterer.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts695" ANNOTATION_ID="a2997208"><ANNOTATION_VALUE>I trained as such for three years.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts698" ANNOTATION_ID="a2997210"><ANNOTATION_VALUE>I/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts698" TIME_SLOT_REF2="ts720" ANNOTATION_ID="a2997214"><ANNOTATION_VALUE>Then, my parents planned to secretly flee to West Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts720" TIME_SLOT_REF2="ts735" ANNOTATION_ID="a3442657"><ANNOTATION_VALUE>Their families had been German for generations.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts767" ANNOTATION_ID="a2997215"><ANNOTATION_VALUE>My grandfather had been a salesman in Hungary during the First World War and was stuck there.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts786" ANNOTATION_ID="a2997216"><ANNOTATION_VALUE>So, my parents wanted to flee, but they didn't tell me because I was so young.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts786" TIME_SLOT_REF2="ts797" ANNOTATION_ID="a2997217"><ANNOTATION_VALUE>Otherwise, I probably would have told other people about it. That wasn't supposed to happen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts820" ANNOTATION_ID="a2997219"><ANNOTATION_VALUE>They had planned everything for a flight. I thought we were just on a trip to Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts820" TIME_SLOT_REF2="ts861" ANNOTATION_ID="a2997221"><ANNOTATION_VALUE>I wondered about the low prices at the hotel, because the communists had told us that the prices in West Germany were horrendously high.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts870" ANNOTATION_ID="a2997222"><ANNOTATION_VALUE>Actually, I didn't really care. The main thing was that we had a bed to sleep in.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts870" TIME_SLOT_REF2="ts903" ANNOTATION_ID="a2997225"><ANNOTATION_VALUE>Then, we received stamped documents from America, France, and England.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts914" ANNOTATION_ID="a2997229"><ANNOTATION_VALUE>Back then, West Berlin was divided into three areas.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts914" TIME_SLOT_REF2="ts924" ANNOTATION_ID="a2997233"><ANNOTATION_VALUE>I wondered about those new documents.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts924" TIME_SLOT_REF2="ts946" ANNOTATION_ID="a2997236"><ANNOTATION_VALUE>Then, my father finally revealed to me that we wouldn't go back home, but that we would stay there.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts946" TIME_SLOT_REF2="ts959" ANNOTATION_ID="a2997238"><ANNOTATION_VALUE>I was really shocked and asked about my girlfriend who had been left behind.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts959" TIME_SLOT_REF2="ts979" ANNOTATION_ID="a2997240"><ANNOTATION_VALUE>We had been a couple for the last two years; we got along very well. And suddenly, I was supposed to leave her behind.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts979" TIME_SLOT_REF2="ts1004" ANNOTATION_ID="a2997242"><ANNOTATION_VALUE>He said I had to choose between going back home and staying there, and having the freedom and opportunity to visit any place in the world.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1004" TIME_SLOT_REF2="ts1009" ANNOTATION_ID="a2997244"><ANNOTATION_VALUE>It wasn't easy for me to choose.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1009" TIME_SLOT_REF2="ts1037" ANNOTATION_ID="a2997246"><ANNOTATION_VALUE>Was I supposed to choose my girlfriend and, thus, living under a communistic regime, over the freedom to travel?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1037" TIME_SLOT_REF2="ts1050" ANNOTATION_ID="a2997248"><ANNOTATION_VALUE>I considered both ideas and chose to follow my parents.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1050" TIME_SLOT_REF2="ts1069" ANNOTATION_ID="a2997251"><ANNOTATION_VALUE>I told my girlfriend that I am sorry and broke up with her. She stayed behind.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1069" TIME_SLOT_REF2="ts1079" ANNOTATION_ID="a2997253"><ANNOTATION_VALUE>So, I could develop further and travel the world.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1079" TIME_SLOT_REF2="ts1101" ANNOTATION_ID="a3741245"><ANNOTATION_VALUE>I am actually really grateful to my father and mother for having taken me with them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1101" TIME_SLOT_REF2="ts1127" ANNOTATION_ID="a2997254"><ANNOTATION_VALUE>Deaf people from Slovakia have told me a lot about the negative things and problems they encountered.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1127" TIME_SLOT_REF2="ts1152" ANNOTATION_ID="a2997256"><ANNOTATION_VALUE>Yet, when coming to Berlin, I realized that Germany was quite different. There is nothing really negative about it, just a lot of positive things to be recognized.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1152" TIME_SLOT_REF2="ts1167" ANNOTATION_ID="a2997258"><ANNOTATION_VALUE>I went to a lot of parties. Thus, I was able to leave things behind and just forget about everything.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1167" TIME_SLOT_REF2="ts1179" ANNOTATION_ID="a2997260"><ANNOTATION_VALUE>I'm much more comfortable now than I used to be.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1179" TIME_SLOT_REF2="ts1199" ANNOTATION_ID="a2997262"><ANNOTATION_VALUE>In the past when I still lived in Slovakia, there were a lot of fights and difficulties.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1199" TIME_SLOT_REF2="ts1208" ANNOTATION_ID="a2997264"><ANNOTATION_VALUE>I feel much better living here in Germany.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1208" TIME_SLOT_REF2="ts1215" ANNOTATION_ID="a2997265"><ANNOTATION_VALUE>That's it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1246" TIME_SLOT_REF2="ts1265" ANNOTATION_ID="a2997284"><ANNOTATION_VALUE>I was still very young when I first came to Germany - I was #X.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1265" TIME_SLOT_REF2="ts1268" ANNOTATION_ID="a2997285"><ANNOTATION_VALUE>Because of/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1268" TIME_SLOT_REF2="ts1272" ANNOTATION_ID="a2997286"><ANNOTATION_VALUE>I/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1272" TIME_SLOT_REF2="ts1290" ANNOTATION_ID="a2997288"><ANNOTATION_VALUE>We came to Germany in ##X8X.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1290" TIME_SLOT_REF2="ts1305" ANNOTATION_ID="a2997290"><ANNOTATION_VALUE>So, I was #X when we moved to Germany.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1305" TIME_SLOT_REF2="ts1338" ANNOTATION_ID="a2997293"><ANNOTATION_VALUE>Initially, they wanted to flee earlier on, but they waited until I had finished my apprenticeship and received my diploma.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1338" TIME_SLOT_REF2="ts1343" ANNOTATION_ID="a2997295"><ANNOTATION_VALUE>Then, they fled and took me along.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1343" TIME_SLOT_REF2="ts1356" ANNOTATION_ID="a2997296"><ANNOTATION_VALUE>Because of my apprenticeship diploma, I could immediately start working.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1356" TIME_SLOT_REF2="ts1391" ANNOTATION_ID="a2997297"><ANNOTATION_VALUE>Back then, I didn't really know a lot of German Sign Language, so I joined the soccer club Comet.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1391" TIME_SLOT_REF2="ts1416" ANNOTATION_ID="a2997300"><ANNOTATION_VALUE>I was amazed by the others' skillful abilities to play soccer. #Name2 and #Name1, for example, were really good. I really wanted to be a part of it, but I just couldn't keep up with them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1416" TIME_SLOT_REF2="ts1423" ANNOTATION_ID="a2997304"><ANNOTATION_VALUE>I then got into the second team.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1423" TIME_SLOT_REF2="ts1450" ANNOTATION_ID="a2997306"><ANNOTATION_VALUE>I watched the others play soccer. They were real pros.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1450" TIME_SLOT_REF2="ts1479" ANNOTATION_ID="a2997310"><ANNOTATION_VALUE>The Germans were really good soccer players. I had been a good player back in Slovakia. Yet, everyone in Germany was twice as good as me.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1479" TIME_SLOT_REF2="ts1496" ANNOTATION_ID="a2997315"><ANNOTATION_VALUE>Those in Berlin were really good. Still, the older players had to leave at some point.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1496" TIME_SLOT_REF2="ts1528" ANNOTATION_ID="a2997318"><ANNOTATION_VALUE>The players in your team were really crazy about sports. They went to the training regularly.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1528" TIME_SLOT_REF2="ts1545" ANNOTATION_ID="a2997332"><ANNOTATION_VALUE>The kids that replaced those players later on weren't as motivated.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1545" TIME_SLOT_REF2="ts1556" ANNOTATION_ID="a2997334"><ANNOTATION_VALUE>They were more interested in partying than in winning.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1556" TIME_SLOT_REF2="ts1573" ANNOTATION_ID="a2997339"><ANNOTATION_VALUE>That was the end of the team - many of the players weren't in the mood to play any longer, and they didn't get into the German soccer championship.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1573" TIME_SLOT_REF2="ts1589" ANNOTATION_ID="a2997342"><ANNOTATION_VALUE>How often did you win the German championship?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1734" TIME_SLOT_REF2="ts1751" ANNOTATION_ID="a2997571"><ANNOTATION_VALUE>Right. Back then, it was a whole other story - you brought home the championship titles.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1751" TIME_SLOT_REF2="ts1764" ANNOTATION_ID="a2997574"><ANNOTATION_VALUE>It didn't work out for us like it did for you guys.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1764" TIME_SLOT_REF2="ts1774" ANNOTATION_ID="a2997577"><ANNOTATION_VALUE>We were supposed to decide on whether we wanted to become more disciplined or not.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1774" TIME_SLOT_REF2="ts1793" ANNOTATION_ID="a2997600"><ANNOTATION_VALUE>Well, that didn't work out either. Berlin is known for long nights of partying.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1793" TIME_SLOT_REF2="ts1801" ANNOTATION_ID="a2997602"><ANNOTATION_VALUE>Yes, that's what it was like.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1801" TIME_SLOT_REF2="ts1838" ANNOTATION_ID="a2997605"><ANNOTATION_VALUE>I just couldn't make any good impression on the ladies in West Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1838" TIME_SLOT_REF2="ts1875" ANNOTATION_ID="a2997618"><ANNOTATION_VALUE>The women in West Berlin were so different; I wasn't able to click with them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1875" TIME_SLOT_REF2="ts1897" ANNOTATION_ID="a2997622"><ANNOTATION_VALUE>I then thought I would be all alone until I die.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1897" TIME_SLOT_REF2="ts1908" ANNOTATION_ID="a2997624"><ANNOTATION_VALUE>I thought I would stay single.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1908" TIME_SLOT_REF2="ts1918" ANNOTATION_ID="a2997626"><ANNOTATION_VALUE>Then the fall of the Berlin Wall happened.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1918" TIME_SLOT_REF2="ts1940" ANNOTATION_ID="a2997636"><ANNOTATION_VALUE>I met a woman from East Berlin. We got along very well - communicating worked well - and we agreed on most topics.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1940" TIME_SLOT_REF2="ts1972" ANNOTATION_ID="a2997638"><ANNOTATION_VALUE>I have been happily married to her for over 20 years now. Now, I have two grown-up sons, as well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1972" TIME_SLOT_REF2="ts1985" ANNOTATION_ID="a2997645"><ANNOTATION_VALUE>If the Berlin Wall hadn't fallen, I would still be alone.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1985" TIME_SLOT_REF2="ts2006" ANNOTATION_ID="a2997647"><ANNOTATION_VALUE>Maybe I would have gotten a wife from China or Africa, who knows?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2017" TIME_SLOT_REF2="ts2021" ANNOTATION_ID="a2997652"><ANNOTATION_VALUE>Exactly.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2036" TIME_SLOT_REF2="ts2041" ANNOTATION_ID="a2997654"><ANNOTATION_VALUE>You would have to find one.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2041" TIME_SLOT_REF2="ts2055" ANNOTATION_ID="a2997655"><ANNOTATION_VALUE>Back then, it just didn't work out with the women from West Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2055" TIME_SLOT_REF2="ts2075" ANNOTATION_ID="a2997657"><ANNOTATION_VALUE>Even though I was in relationships a couple of times, it just wouldn't work out. We split up each time.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2075" TIME_SLOT_REF2="ts2108" ANNOTATION_ID="a2997665"><ANNOTATION_VALUE>We weren't on the same wavelength; we never agreed on anything.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2108" TIME_SLOT_REF2="ts2111" ANNOTATION_ID="a2997666"><ANNOTATION_VALUE>On the other hand, women from East Germany and I got along very well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2111" TIME_SLOT_REF2="ts2133" ANNOTATION_ID="a2997669"><ANNOTATION_VALUE>It was by chance that I found my wife. Thanks to the fall of the Berlin Wall.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2278" TIME_SLOT_REF2="ts2307" ANNOTATION_ID="a2997780"><ANNOTATION_VALUE>Right. Before the fall of the Berlin Wall, women in East Germany had to put up with the men's behavior a lot.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2307" TIME_SLOT_REF2="ts2321" ANNOTATION_ID="a2997786"><ANNOTATION_VALUE>They drank a lot and treated their wives badly.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2321" TIME_SLOT_REF2="ts2344" ANNOTATION_ID="a2997788"><ANNOTATION_VALUE>After the fall of the Berlin Wall, those women found new nicer men from West Germany. From that moment on there were a lot of breakups.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2344" TIME_SLOT_REF2="ts2359" ANNOTATION_ID="a2997789"><ANNOTATION_VALUE>The men from the East were mad at us because we had stolen their wives and girlfriends.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2359" TIME_SLOT_REF2="ts2387" ANNOTATION_ID="a2997816"><ANNOTATION_VALUE>You're not supposed to do so. You shouldn't treat women badly. Women shouldn't have to put up with that.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2387" TIME_SLOT_REF2="ts2408" ANNOTATION_ID="a2997820"><ANNOTATION_VALUE>Furthermore, someone who had a job in East Germany was happy with everything.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2408" TIME_SLOT_REF2="ts2433" ANNOTATION_ID="a2997824"><ANNOTATION_VALUE>People who didn't have jobs said that they wanted the Berlin Wall back in place.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2433" TIME_SLOT_REF2="ts2456" ANNOTATION_ID="a2997827"><ANNOTATION_VALUE>That's how easy it is to read those people's faces.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2463" TIME_SLOT_REF2="ts2494" ANNOTATION_ID="a2997838"><ANNOTATION_VALUE>It was the same in West Germany: people who had jobs before and after the fall of the Berlin Wall were completely pleased with what they had.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2494" TIME_SLOT_REF2="ts2526" ANNOTATION_ID="a2997841"><ANNOTATION_VALUE>If they didn't have a job, they thought it would be better to restore the Berlin wall.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2526" TIME_SLOT_REF2="ts2536" ANNOTATION_ID="a2997844"><ANNOTATION_VALUE>It was the same in the East and in the West.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2538" TIME_SLOT_REF2="ts2554" ANNOTATION_ID="a2997851"><ANNOTATION_VALUE>The deaf people in Slovakia are as follows:</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2554" TIME_SLOT_REF2="ts2586" ANNOTATION_ID="a2997856"><ANNOTATION_VALUE>They really focused on sports because sports were government-sponsored.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2586" TIME_SLOT_REF2="ts2610" ANNOTATION_ID="a2997859"><ANNOTATION_VALUE>There weren't many cultural activities around. Everything was about sports.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2610" TIME_SLOT_REF2="ts2621" ANNOTATION_ID="a2997860"><ANNOTATION_VALUE>That influenced me to a great extent.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2621" TIME_SLOT_REF2="ts2648" ANNOTATION_ID="a2997866"><ANNOTATION_VALUE>After I had fled to Berlin, I realized that there weren't just sports around. I was able to be involved in other cultural activities with deaf people.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2648" TIME_SLOT_REF2="ts2665" ANNOTATION_ID="a2997870"><ANNOTATION_VALUE>There was a lot of Deaf Culture because of people like Puttrich and Jochen Muhs.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2665" TIME_SLOT_REF2="ts2672" ANNOTATION_ID="a2997877"><ANNOTATION_VALUE>I learnt a lot from them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2672" TIME_SLOT_REF2="ts2682" ANNOTATION_ID="a2997878"><ANNOTATION_VALUE>Now, I know a lot more about the culture.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2682" TIME_SLOT_REF2="ts2695" ANNOTATION_ID="a2997882"><ANNOTATION_VALUE>Under communism people could only think of sports.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2695" TIME_SLOT_REF2="ts2702" ANNOTATION_ID="a2997886"><ANNOTATION_VALUE>Those are some differences between living here and living there.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2702" TIME_SLOT_REF2="ts2741" ANNOTATION_ID="a2997894"><ANNOTATION_VALUE>Now, I even get to experience some more cultural life because I'm getting too old to engage in sports any longer.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2772" TIME_SLOT_REF2="ts2788" ANNOTATION_ID="a2997913"><ANNOTATION_VALUE>When I did sports back then/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2788" TIME_SLOT_REF2="ts2819" ANNOTATION_ID="a2997916"><ANNOTATION_VALUE>With soccer, where everybody played really well, I was usually just a substitute and endured that.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2819" TIME_SLOT_REF2="ts2848" ANNOTATION_ID="a2997926"><ANNOTATION_VALUE>(Back then, away games were funded. That's the only reason I attended soccer regularly.)</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2848" TIME_SLOT_REF2="ts2881" ANNOTATION_ID="a2997935"><ANNOTATION_VALUE>There are lots of really good players in the same team nowadays. Yet, those don't want to be substitutes and sit on a bench for most of the match. That's why they leave the team.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2881" TIME_SLOT_REF2="ts2886" ANNOTATION_ID="a2997950"><ANNOTATION_VALUE>This amounted to a loss of players.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2886" TIME_SLOT_REF2="ts2897" ANNOTATION_ID="a2997953"><ANNOTATION_VALUE>Even if they were really good at playing soccer, they were also really arrogant and had a problem with being substitutes.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2897" TIME_SLOT_REF2="ts2917" ANNOTATION_ID="a2997960"><ANNOTATION_VALUE>Even if I am a good soccer player myself, I have to encourage and support my teammates. That's good for the entire team.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2917" TIME_SLOT_REF2="ts2931" ANNOTATION_ID="a2997962"><ANNOTATION_VALUE>Yet, those players were different; that's why they had so much trouble.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2931" TIME_SLOT_REF2="ts2938" ANNOTATION_ID="a2997964"><ANNOTATION_VALUE>Either way, the club Comet is in real trouble now.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2938" TIME_SLOT_REF2="ts2969" ANNOTATION_ID="a2997966"><ANNOTATION_VALUE>You can tell that at least 80% of the players for Comet are foreigners; only a few of them are German.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2969" TIME_SLOT_REF2="ts3000" ANNOTATION_ID="a2997967"><ANNOTATION_VALUE>They are in good shape physically - especially the young Turks.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Moderator" LINGUISTIC_TYPE_REF="L_text__finer_granularity" PARTICIPANT="ber-mod-2"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2537" TIME_SLOT_REF2="ts2538" ANNOTATION_ID="a2563627"><ANNOTATION_VALUE>Kannst du was über die Unterschiede zwischen Berlin und Bratislava erzählen?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_Mod" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="ber-mod-2"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2537" TIME_SLOT_REF2="ts2538" ANNOTATION_ID="a2997847"><ANNOTATION_VALUE>Can you talk about the differences between Berlin and Bratislava?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__coarser_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_dependent_values" TIME_ALIGNABLE="false" CONSTRAINTS="Symbolic_Association"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_tokens_right_left__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__mouth__standard_orthography__coarser_granularity" TIME_ALIGNABLE="true"/><CONSTRAINT STEREOTYPE="Symbolic_Association" DESCRIPTION="1-1 association with a parent annotation"/></ANNOTATION_DOCUMENT>
