ON_VALUE>leben</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2745" TIME_SLOT_REF2="ts2746" ANNOTATION_ID="a2385632"><ANNOTATION_VALUE>in</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2747" TIME_SLOT_REF2="ts2748" ANNOTATION_ID="a2385636"><ANNOTATION_VALUE>berlin</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2749" TIME_SLOT_REF2="ts2750" ANNOTATION_ID="a2396138"><ANNOTATION_VALUE>wie</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2751" TIME_SLOT_REF2="ts2752" ANNOTATION_ID="a2385679"><ANNOTATION_VALUE>flexibel</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2753" TIME_SLOT_REF2="ts2754" ANNOTATION_ID="a2385731"><ANNOTATION_VALUE>sport</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2755" TIME_SLOT_REF2="ts2756" ANNOTATION_ID="a2973510"><ANNOTATION_VALUE>andere seite</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2757" TIME_SLOT_REF2="ts2760" ANNOTATION_ID="a2385736"><ANNOTATION_VALUE>kultur</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2766" TIME_SLOT_REF2="ts2767" ANNOTATION_ID="a2396159"><ANNOTATION_VALUE>immer</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2768" TIME_SLOT_REF2="ts2771" ANNOTATION_ID="a2396161"><ANNOTATION_VALUE>sport</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2773" TIME_SLOT_REF2="ts2774" ANNOTATION_ID="a2396165"><ANNOTATION_VALUE>auch nicht gut</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2862" TIME_SLOT_REF2="ts2864" ANNOTATION_ID="a2397367"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2866" TIME_SLOT_REF2="ts2868" ANNOTATION_ID="a2397371"><ANNOTATION_VALUE>abhauen</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2870" TIME_SLOT_REF2="ts2874" ANNOTATION_ID="a2397372"><ANNOTATION_VALUE>abhauen</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2989" TIME_SLOT_REF2="ts2990" ANNOTATION_ID="a2401518"><ANNOTATION_VALUE>weil</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2992" TIME_SLOT_REF2="ts2998" ANNOTATION_ID="a2401522"><ANNOTATION_VALUE>familie</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2999" TIME_SLOT_REF2="ts3000" ANNOTATION_ID="a2401528"><ANNOTATION_VALUE>früher</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts3001" TIME_SLOT_REF2="ts3004" ANNOTATION_ID="a2401555"><ANNOTATION_VALUE>auswandern</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts3005" TIME_SLOT_REF2="ts3006" ANNOTATION_ID="a2401567"><ANNOTATION_VALUE>und durch</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts3007" TIME_SLOT_REF2="ts3008" ANNOTATION_ID="a2401576"><ANNOTATION_VALUE>kind</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts3009" TIME_SLOT_REF2="ts3010" ANNOTATION_ID="a2401573"><ANNOTATION_VALUE>groß</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_A" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="ber-12"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1215" TIME_SLOT_REF2="ts1234" ANNOTATION_ID="a2997281"><ANNOTATION_VALUE>Because of your parents you got to come here; you were still quite naive.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1234" TIME_SLOT_REF2="ts1246" ANNOTATION_ID="a2997282"><ANNOTATION_VALUE>You got lucky with life.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1268" TIME_SLOT_REF2="ts1282" ANNOTATION_ID="a2997287"><ANNOTATION_VALUE>When did you move here?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1282" TIME_SLOT_REF2="ts1288" ANNOTATION_ID="a2997289"><ANNOTATION_VALUE>Ah, in ##X8X.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1586" TIME_SLOT_REF2="ts1603" ANNOTATION_ID="a2997343"><ANNOTATION_VALUE>We won the championship in #X81.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1603" TIME_SLOT_REF2="ts1622" ANNOTATION_ID="a2997344"><ANNOTATION_VALUE>It all ended in ##X8X. I've won the German championship three times in my life.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1622" TIME_SLOT_REF2="ts1629" ANNOTATION_ID="a2997346"><ANNOTATION_VALUE>I was once runner-up, as well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1629" TIME_SLOT_REF2="ts1638" ANNOTATION_ID="a2997347"><ANNOTATION_VALUE>But the championship was only held every second year.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1638" TIME_SLOT_REF2="ts1645" ANNOTATION_ID="a2997348"><ANNOTATION_VALUE>There is one every year nowadays; it's much quicker that way.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1645" TIME_SLOT_REF2="ts1672" ANNOTATION_ID="a2997350"><ANNOTATION_VALUE>If we had had a championship every year back then, we surely would have won many times more, certainly seven or eight times.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1672" TIME_SLOT_REF2="ts1677" ANNOTATION_ID="a2997353"><ANNOTATION_VALUE>Because it only took place every second year, winning more than once took much longer.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1677" TIME_SLOT_REF2="ts1692" ANNOTATION_ID="a2997355"><ANNOTATION_VALUE>So, ideally there should have been five championship titles within a time span of ten years.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1692" TIME_SLOT_REF2="ts1707" ANNOTATION_ID="a2997358"><ANNOTATION_VALUE>If you didn't win, winning the title wasn't possible for a longer time.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1707" TIME_SLOT_REF2="ts1734" ANNOTATION_ID="a2997564"><ANNOTATION_VALUE>Now, there's a championship in Düsseldorf or Stuttgart every single year, so winning seven or eight championship titles isn't that big of a deal.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2004" TIME_SLOT_REF2="ts2008" ANNOTATION_ID="a2997648"><ANNOTATION_VALUE>That wouldn't have worked either.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2008" TIME_SLOT_REF2="ts2017" ANNOTATION_ID="a2997650"><ANNOTATION_VALUE>She would have spoken another language. That wouldn't have fit either.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2017" TIME_SLOT_REF2="ts2036" ANNOTATION_ID="a2997653"><ANNOTATION_VALUE>I, as a German-born man should marry a German woman.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2134" TIME_SLOT_REF2="ts2155" ANNOTATION_ID="a2997704"><ANNOTATION_VALUE>Yet, more difficulties like those in the financial sector arose due to the fall of the Berlin Wall.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2155" TIME_SLOT_REF2="ts2170" ANNOTATION_ID="a2997707"><ANNOTATION_VALUE>More and more deaf people became unemployed.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2170" TIME_SLOT_REF2="ts2193" ANNOTATION_ID="a2997708"><ANNOTATION_VALUE>Before the fall of the Berlin Wall, almost 80% of the deaf people still had a job, whereas only 20% were unemployed.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2193" TIME_SLOT_REF2="ts2212" ANNOTATION_ID="a2997712"><ANNOTATION_VALUE>Nowadays, it's the other way around: only 20% have a job and 80% are unemployed.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2212" TIME_SLOT_REF2="ts2238" ANNOTATION_ID="a2997718"><ANNOTATION_VALUE>Many of the deaf people from East Germany lost their jobs after the fall of the Berlin Wall because they didn't know anything about the new technologies that were used in West Germany.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2238" TIME_SLOT_REF2="ts2267" ANNOTATION_ID="a2997727"><ANNOTATION_VALUE>They had worked with technologies common in the GDR. After the change, they just didn't know the construction of machines from West Germany.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2267" TIME_SLOT_REF2="ts2278" ANNOTATION_ID="a2997738"><ANNOTATION_VALUE>That was a problem. Many jobs were axed.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2433" TIME_SLOT_REF2="ts2463" ANNOTATION_ID="a2997829"><ANNOTATION_VALUE>Yes, those are two opposing views.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2741" TIME_SLOT_REF2="ts2760" ANNOTATION_ID="a2997896"><ANNOTATION_VALUE>That's living in Berlin: you're quite flexible, and you're able to choose between sports and other cultural activities.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2760" TIME_SLOT_REF2="ts2765" ANNOTATION_ID="a2997898"><ANNOTATION_VALUE>You have the choice.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2765" TIME_SLOT_REF2="ts2780" ANNOTATION_ID="a2997905"><ANNOTATION_VALUE>You can't do sports all the time. You need some change at times.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2860" TIME_SLOT_REF2="ts2881" ANNOTATION_ID="a2997939"><ANNOTATION_VALUE>Right, that's ridiculous. They just take off.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2985" TIME_SLOT_REF2="ts3011" ANNOTATION_ID="a2997969"><ANNOTATION_VALUE>Yes, their families emigrated back in the days. Now those children are all grown-up.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Deutsche_&#xDC;bersetzung_B" LINGUISTIC_TYPE_REF="L_text__finer_granularity" PARTICIPANT="ber-13"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts16" ANNOTATION_ID="a2558025"><ANNOTATION_VALUE>Meine Familie ist in der vierten Generation gehörlos.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts16" TIME_SLOT_REF2="ts20" ANNOTATION_ID="a2878582"><ANNOTATION_VALUE>Ich gehöre zur fünften Generation.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts20" TIME_SLOT_REF2="ts49" ANNOTATION_ID="a2558048"><ANNOTATION_VALUE>Ich bin dann nicht im Heim aufgewachsen, sondern immer zur Gehörlosenschule gependelt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts72" ANNOTATION_ID="a2558050"><ANNOTATION_VALUE>Als ich fünf Jahre alt war, fing ich mit der Schule an.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts72" TIME_SLOT_REF2="ts89" ANNOTATION_ID="a2774661"><ANNOTATION_VALUE>Ich konnte schon gebärden, alle anderen dagegen nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts106" ANNOTATION_ID="a2558061"><ANNOTATION_VALUE>Sie kamen ja aus Dörfern von außerhalb und konnten nicht gebärden.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts143" ANNOTATION_ID="a2558062"><ANNOTATION_VALUE>Ich konnte nicht mit denen gebärden und war frustriert, also suchte ich lieber Kontakt zu den Größeren, z.B. zu denen aus der 3. oder 4. Klasse.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts158" ANNOTATION_ID="a2558064"><ANNOTATION_VALUE>Einerseits war es gut, dass ich nun Kontakte hatte und mich mit anderen unterhalten konnte.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts158" TIME_SLOT_REF2="ts176" ANNOTATION_ID="a2558066"><ANNOTATION_VALUE>Aber andererseits wurde ich oft vorgeschickt, um etwas für sie zu machen. Da musste ich viel auf mich nehmen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts176" TIME_SLOT_REF2="ts209" ANNOTATION_ID="a2558068"><ANNOTATION_VALUE>Wenn ich mit ihnen befreundet sein und von ihnen beschützt werden wollte, musste ich im Gegenzug vieles erdulden.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts225" ANNOTATION_ID="a2558070"><ANNOTATION_VALUE>Ja, ich war eher mit Größeren zusammen, als mit Gleichaltrigen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts257" ANNOTATION_ID="a2558072"><ANNOTATION_VALUE>Die Zeit verging so schnell, die Älteren waren längst aus der Schule entlassen und ich inzwischen in der 9. Klasse.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts288" ANNOTATION_ID="a2558074"><ANNOTATION_VALUE>Nun hatte ich nur Gleichaltrige und Jüngere, sie waren alle nicht so gut im Gebärden.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts288" TIME_SLOT_REF2="ts306" ANNOTATION_ID="a2973278"><ANNOTATION_VALUE>Ich fuhr stattdessen öfter zu Ausbildungsstellen, wo ich auf Gehörlose traf, die ich von früher kannte, um mich mit ihnen zu unterhalten.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts306" TIME_SLOT_REF2="ts314" ANNOTATION_ID="a2558081"><ANNOTATION_VALUE>Die anderen dachten dabei wohl, ich sei mir zu fein für sie.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts314" TIME_SLOT_REF2="ts321" ANNOTATION_ID="a2706429"><ANNOTATION_VALUE>Aber weil ich mich bei ihnen eh nicht wohl fühlte, kümmerte mich das nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts344" ANNOTATION_ID="a2994982"><ANNOTATION_VALUE>Und da fragte meine Mutter mich, was ich für einen Beruf erlernen wolle.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts344" TIME_SLOT_REF2="ts364" ANNOTATION_ID="a2774679"><ANNOTATION_VALUE>Ich hatte sehr gute Noten.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts364" TIME_SLOT_REF2="ts376" ANNOTATION_ID="a2878623"><ANNOTATION_VALUE>Auf dem Zeugnis früher waren überall Einsen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts376" TIME_SLOT_REF2="ts396" ANNOTATION_ID="a2558087"><ANNOTATION_VALUE>Damals gab es ja keine Realschule oder andere weiterführende Möglichkeiten für Gehörlose.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts396" TIME_SLOT_REF2="ts425" ANNOTATION_ID="a2706478"><ANNOTATION_VALUE>Ich musste also mit den anderen zusammen sitzen, obwohl ich denen sehr weit voraus war.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts445" ANNOTATION_ID="a2558098"><ANNOTATION_VALUE>Meine Mutter sprach mit dem Schuldirektor und fragte nach seiner Empfehlung.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts464" ANNOTATION_ID="a2558100"><ANNOTATION_VALUE>Er meinte, ich solle es mal mit der Schwerhörigenschule versuchen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts464" TIME_SLOT_REF2="ts474" ANNOTATION_ID="a2558108"><ANNOTATION_VALUE>Ich fand seine Idee gut.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts474" TIME_SLOT_REF2="ts501" ANNOTATION_ID="a2774697"><ANNOTATION_VALUE>Ich sagte meiner Mutter, die auch gehörlos ist, dass ich dorthin gehen wolle.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts506" ANNOTATION_ID="a2560270"><ANNOTATION_VALUE>Aber meine Mutter lehnte ab.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts506" TIME_SLOT_REF2="ts530" ANNOTATION_ID="a2878632"><ANNOTATION_VALUE>Denn sie meinte, die Schwerhörigen seien mit sich nicht ganz im Reinen, und dass es dadurch oft Probleme, z.B. mit Mobbing, gäbe.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts530" TIME_SLOT_REF2="ts539" ANNOTATION_ID="a2561022"><ANNOTATION_VALUE>Meine Mutter wollte das nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts548" ANNOTATION_ID="a2561023"><ANNOTATION_VALUE>„Bei den Gehörlosen bist du besser aufgehoben, das sind ehrliche Menschen.“</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts548" TIME_SLOT_REF2="ts561" ANNOTATION_ID="a2561024"><ANNOTATION_VALUE>Meine Mutter meinte, die Schwerhörigen wüssten nicht so richtig, wohin mit sich.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts569" ANNOTATION_ID="a2561025"><ANNOTATION_VALUE>Darum wollte sie gar nicht, dass ich auf eine Schwerhörigenschule ging.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts576" ANNOTATION_ID="a2973286"><ANNOTATION_VALUE>Ich war enttäuscht darüber und musste wohl oder übel in der Gehörlosenschule bleiben.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts576" TIME_SLOT_REF2="ts592" ANNOTATION_ID="a2561027"><ANNOTATION_VALUE>Dort blieb ich dann bis zu meiner Entlassung, nach der ich eine Ausbildung anfing.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts592" TIME_SLOT_REF2="ts610" ANNOTATION_ID="a2561028"><ANNOTATION_VALUE>Man war gezwungen, sich aus zehn Berufen einen auszuwählen, andere gab es nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts610" TIME_SLOT_REF2="ts621" ANNOTATION_ID="a2561029"><ANNOTATION_VALUE>Also Schneider, Polsterer und Tischler.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts621" TIME_SLOT_REF2="ts630" ANNOTATION_ID="a2561030"><ANNOTATION_VALUE>Ich wollte gerne etwas Besseres, aber das gab es nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts630" TIME_SLOT_REF2="ts658" ANNOTATION_ID="a2561031"><ANNOTATION_VALUE>Damals, in den 70ern bei den Kommunisten, war das halt nicht möglich. Da konnte man nichts machen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts658" TIME_SLOT_REF2="ts683" ANNOTATION_ID="a2561032"><ANNOTATION_VALUE>Ich musste aus diesen zehn Berufen einen auswählen und versuchte es mit Polsterer.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts695" ANNOTATION_ID="a2561033"><ANNOTATION_VALUE>Und lernte das für drei Jahre.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts698" ANNOTATION_ID="a2886732"><ANNOTATION_VALUE>Ich/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts698" TIME_SLOT_REF2="ts720" ANNOTATION_ID="a2561034"><ANNOTATION_VALUE>Dann wollten meine Mutter und mein Vater heimlich nach Westberlin fliehen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts720" TIME_SLOT_REF2="ts735" ANNOTATION_ID="a3442649"><ANNOTATION_VALUE>Ihre Familien stammen seit Generationen aus Deutschland.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts767" ANNOTATION_ID="a2561035"><ANNOTATION_VALUE>Mein Opa war während des ersten Weltkrieges Geschäftsmann in Ungarn und saß da fest.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts786" ANNOTATION_ID="a2561036"><ANNOTATION_VALUE>Also, meine Eltern wollten fliehen, sagten mir aber nichts davon, weil ich so jung war.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts786" TIME_SLOT_REF2="ts797" ANNOTATION_ID="a2973292"><ANNOTATION_VALUE>Denn sonst hätte ich es nicht für mich behalten und stattdessen anderen weitererzählen können. Das durfte nicht passieren.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts820" ANNOTATION_ID="a2973295"><ANNOTATION_VALUE>Sie planten also alles für die Flucht, ich dachte, wir seien in Berlin auf einer Urlaubsreise.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts820" TIME_SLOT_REF2="ts861" ANNOTATION_ID="a2561039"><ANNOTATION_VALUE>Im Hotel wunderte ich mich über die günstigen Preise, die Kommunisten hatten erzählt, dass alles im Westen teuer sei.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts870" ANNOTATION_ID="a2706600"><ANNOTATION_VALUE>Aber eigentlich war mir das auch egal, Hauptsache wir hatten ein Bett.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts870" TIME_SLOT_REF2="ts903" ANNOTATION_ID="a2561040"><ANNOTATION_VALUE>Dann bekamen wir gestempelte Papiere ausgehändigt, von Amerika, Frankreich und England.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts914" ANNOTATION_ID="a2561041"><ANNOTATION_VALUE>Damals war Westberlin ja getrennt in drei Zonen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts914" TIME_SLOT_REF2="ts924" ANNOTATION_ID="a2561042"><ANNOTATION_VALUE>Ich wunderte mich sehr über diese neuen Papiere.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts924" TIME_SLOT_REF2="ts946" ANNOTATION_ID="a2561043"><ANNOTATION_VALUE>Dann offenbarte mir mein Vater, dass wir nicht mehr zurück nach Hause fahren, sondern hier bleiben würden.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts946" TIME_SLOT_REF2="ts959" ANNOTATION_ID="a2561044"><ANNOTATION_VALUE>Ich erschrak sehr und fragte nach meiner Freundin, die ja zurückgeblieben war.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts959" TIME_SLOT_REF2="ts979" ANNOTATION_ID="a2561045"><ANNOTATION_VALUE>Mit ihr war ich zwei Jahre lang zusammen und wir verstanden uns gut, und nun sollte ich sie zu Hause zurücklassen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts979" TIME_SLOT_REF2="ts1004" ANNOTATION_ID="a2561046"><ANNOTATION_VALUE>Er meinte, ich hätte die Wahl zwischen dem Zurückgehen und Dortbleiben oder der Freiheit sowie der Möglichkeit, überall auf der Welt reisen zu dürfen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1004" TIME_SLOT_REF2="ts1009" ANNOTATION_ID="a2561047"><ANNOTATION_VALUE>Es fiel mir nicht leicht, zu entscheiden.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1009" TIME_SLOT_REF2="ts1037" ANNOTATION_ID="a2561048"><ANNOTATION_VALUE>Sollte ich mich für meine Freundin und damit dafür entscheiden, im Kommunismus leben zu müssen oder für die Freiheit zu reisen?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1037" TIME_SLOT_REF2="ts1050" ANNOTATION_ID="a2561049"><ANNOTATION_VALUE>Ich überlegte und entschied mich dafür, meinen Eltern zu folgen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1050" TIME_SLOT_REF2="ts1069" ANNOTATION_ID="a2973327"><ANNOTATION_VALUE>Ich habe meiner Freundin gesagt, dass es mir leidtut, und sie verlassen. Sie blieb dann daheim.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1069" TIME_SLOT_REF2="ts1079" ANNOTATION_ID="a2561051"><ANNOTATION_VALUE>Ich konnte mich weiterentwickeln und die Welt bereisen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1079" TIME_SLOT_REF2="ts1101" ANNOTATION_ID="a3741242"><ANNOTATION_VALUE>Jetzt bin ich meinen Eltern dankbar, dass sie mich mitgenommen haben.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1101" TIME_SLOT_REF2="ts1127" ANNOTATION_ID="a2561052"><ANNOTATION_VALUE>Die Gehörlosen aus der Slowakei haben mir von vielen Problemen und negativen Dingen erzählt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1127" TIME_SLOT_REF2="ts1152" ANNOTATION_ID="a2706609"><ANNOTATION_VALUE>Aber als ich nach Berlin kam, habe ich festgestellt, dass es in Deutschland anders ist. Es gibt hier wenig Negatives, sondern mehr Positives.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1152" TIME_SLOT_REF2="ts1167" ANNOTATION_ID="a2561053"><ANNOTATION_VALUE>Ich habe viel gefeiert und konnte alles andere vergessen und hinter mir lassen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1167" TIME_SLOT_REF2="ts1179" ANNOTATION_ID="a2561054"><ANNOTATION_VALUE>Ich fühle mich hier wohl, besser als vorher.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1179" TIME_SLOT_REF2="ts1199" ANNOTATION_ID="a2878634"><ANNOTATION_VALUE>Als ich früher in der Slowakei war, gab es dort Streitereien und Probleme.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1199" TIME_SLOT_REF2="ts1208" ANNOTATION_ID="a2878635"><ANNOTATION_VALUE>Hier in Deutschland geht es mir besser.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1208" TIME_SLOT_REF2="ts1215" ANNOTATION_ID="a2561055"><ANNOTATION_VALUE>So läuft es bisher.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1246" TIME_SLOT_REF2="ts1265" ANNOTATION_ID="a2995089"><ANNOTATION_VALUE>Ich war noch jung, als ich hierher kam, #X Jahre.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1265" TIME_SLOT_REF2="ts1268" ANNOTATION_ID="a2562951"><ANNOTATION_VALUE>Durch/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1268" TIME_SLOT_REF2="ts1272" ANNOTATION_ID="a2562957"><ANNOTATION_VALUE>Ich/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1272" TIME_SLOT_REF2="ts1290" ANNOTATION_ID="a2706632"><ANNOTATION_VALUE>Wir sind ##X8X hierher gekommen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1290" TIME_SLOT_REF2="ts1305" ANNOTATION_ID="a2562973"><ANNOTATION_VALUE>Also ich war #X, als wir hierher zogen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1305" TIME_SLOT_REF2="ts1338" ANNOTATION_ID="a2562979"><ANNOTATION_VALUE>Eigentlich wollten sie es schon viel früher tun, aber sie hatten abgewartet, bis ich meine Ausbildung beendete und einen Gesellenbrief bekam.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1338" TIME_SLOT_REF2="ts1343" ANNOTATION_ID="a2973348"><ANNOTATION_VALUE>Dann sind sie geflüchtet und haben mich mitgenommen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1343" TIME_SLOT_REF2="ts1356" ANNOTATION_ID="a2562984"><ANNOTATION_VALUE>Da ich diesen Brief hatte, konnte ich gleich arbeiten gehen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1356" TIME_SLOT_REF2="ts1391" ANNOTATION_ID="a2562989"><ANNOTATION_VALUE>Damals konnte ich die Deutsche Gebärdensprache nicht gut und bin dann dem Fußballverein Comet beigetreten.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1391" TIME_SLOT_REF2="ts1416" ANNOTATION_ID="a2562994"><ANNOTATION_VALUE>Ich staunte über die Fußballkunst der anderen dort. #Name2 und #Name1 z.B. waren echt gut. Ich wollte gern mitmachen, konnte aber nicht mithalten.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1416" TIME_SLOT_REF2="ts1423" ANNOTATION_ID="a2562998"><ANNOTATION_VALUE>Ich war dann in der zweiten Mannschaft.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1423" TIME_SLOT_REF2="ts1450" ANNOTATION_ID="a2563008"><ANNOTATION_VALUE>Ich hab mir angesehen, wie die anderen spielten. Die waren richtige Profis.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1450" TIME_SLOT_REF2="ts1479" ANNOTATION_ID="a2563007"><ANNOTATION_VALUE>Die Deutschen waren im Fußball stark. In der Slowakei war ich ein guter Spieler, aber als ich dann nach Deutschland kam, waren die doppelt so stark wie ich.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1479" TIME_SLOT_REF2="ts1496" ANNOTATION_ID="a2736944"><ANNOTATION_VALUE>In Berlin waren die stark. Trotzdem mussten die Älteren dann irgendwann weichen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1496" TIME_SLOT_REF2="ts1528" ANNOTATION_ID="a2563013"><ANNOTATION_VALUE>Damals in deiner Mannschaft waren alle ja sportbegeistert. Sie kamen regelmäßig zum Training.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1528" TIME_SLOT_REF2="ts1545" ANNOTATION_ID="a2878636"><ANNOTATION_VALUE>Der Nachwuchs, der sie später ersetzte, war nicht so sportbegeistert.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1545" TIME_SLOT_REF2="ts1556" ANNOTATION_ID="a2563022"><ANNOTATION_VALUE>Sie feierten lieber und waren daran nicht so interessiert, siegreich zu sein.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1556" TIME_SLOT_REF2="ts1573" ANNOTATION_ID="a2563027"><ANNOTATION_VALUE>Damit ging die Mannschaft kaputt, viele hatten dann keine Lust mehr und schafften es nicht mehr bei der Deutschen Meisterschaft.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1573" TIME_SLOT_REF2="ts1589" ANNOTATION_ID="a2563030"><ANNOTATION_VALUE>Wie oft wart ihr damals Deutscher Meister?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1734" TIME_SLOT_REF2="ts1751" ANNOTATION_ID="a2563191"><ANNOTATION_VALUE>Ja, damals war das so eine andere Geschichte, da habt ihr Titel geholt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1751" TIME_SLOT_REF2="ts1764" ANNOTATION_ID="a2563192"><ANNOTATION_VALUE>Bei uns aber klappte es nicht so recht wie bei euch damals.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1764" TIME_SLOT_REF2="ts1774" ANNOTATION_ID="a2563194"><ANNOTATION_VALUE>Wir sollten uns entscheiden, ob wir disziplinierter werden wollten oder nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1774" TIME_SLOT_REF2="ts1793" ANNOTATION_ID="a2973374"><ANNOTATION_VALUE>Aber damit klappte es auch nicht, Berlin als Hauptstadt ist ja berühmt für durchzechte Nächte.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1793" TIME_SLOT_REF2="ts1801" ANNOTATION_ID="a2563196"><ANNOTATION_VALUE>Ja, so war es.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1801" TIME_SLOT_REF2="ts1838" ANNOTATION_ID="a2563197"><ANNOTATION_VALUE>Bei mir damals in Westberlin wollte es mit den Frauen nicht so recht klappen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1838" TIME_SLOT_REF2="ts1875" ANNOTATION_ID="a2563198"><ANNOTATION_VALUE>Die Frauen aus Westberlin waren irgendwie anders, mit denen konnte ich einfach keine Beziehung aufbauen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1875" TIME_SLOT_REF2="ts1897" ANNOTATION_ID="a2706716"><ANNOTATION_VALUE>Ich dachte dann, ich werde wohl allein bleiben, bis ich alt und begraben bin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1897" TIME_SLOT_REF2="ts1908" ANNOTATION_ID="a2737001"><ANNOTATION_VALUE>Ich dachte, ich bleib eben allein.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1908" TIME_SLOT_REF2="ts1918" ANNOTATION_ID="a2563200"><ANNOTATION_VALUE>Dann kam der Mauerfall.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1918" TIME_SLOT_REF2="ts1940" ANNOTATION_ID="a2878637"><ANNOTATION_VALUE>Ich lernte eine Ostberlinerin kennen, mit der ich mich gut verstand, mit der die Kommunikation gut funktionierte und wir waren oft einer Meinung.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1940" TIME_SLOT_REF2="ts1955" ANNOTATION_ID="a2706721"><ANNOTATION_VALUE>Ich bin bis heute glücklich mit ihr verheiratet.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1955" TIME_SLOT_REF2="ts1972" ANNOTATION_ID="a2563208"><ANNOTATION_VALUE>Schon über 20 Jahre und ich habe nun zwei große Söhne.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1972" TIME_SLOT_REF2="ts1985" ANNOTATION_ID="a2563213"><ANNOTATION_VALUE>Wenn es den Mauerfall nicht gegeben hätte, dann wäre ich heute immer noch allein.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1985" TIME_SLOT_REF2="ts2006" ANNOTATION_ID="a2706724"><ANNOTATION_VALUE>Oder ich hätte mir halt eine Frau aus China oder Afrika genommen, wer weiß.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2017" TIME_SLOT_REF2="ts2021" ANNOTATION_ID="a2563239"><ANNOTATION_VALUE>Ja, eben.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2036" TIME_SLOT_REF2="ts2041" ANNOTATION_ID="a2706742"><ANNOTATION_VALUE>Die müsstest du finden.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2041" TIME_SLOT_REF2="ts2055" ANNOTATION_ID="a2563252"><ANNOTATION_VALUE>Damals in Westberlin wollte es mit den Frauen nicht so recht klappen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2055" TIME_SLOT_REF2="ts2075" ANNOTATION_ID="a2563255"><ANNOTATION_VALUE>Zwar war ich mit einigen zusammen, aber jedes Mal funktionierte es nicht. Wir trennten uns wieder.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2075" TIME_SLOT_REF2="ts2108" ANNOTATION_ID="a2563261"><ANNOTATION_VALUE>Wir waren einfach nicht auf einer Wellenlänge und auch nicht einer Meinung.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2108" TIME_SLOT_REF2="ts2111" ANNOTATION_ID="a2737028"><ANNOTATION_VALUE>Mit denen aus dem Osten dagegen sehr wohl.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2111" TIME_SLOT_REF2="ts2133" ANNOTATION_ID="a2706761"><ANNOTATION_VALUE>Es war nur ein Zufall, dass ich doch eine Frau habe. Dank des Mauerfalls.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2278" TIME_SLOT_REF2="ts2307" ANNOTATION_ID="a2563306"><ANNOTATION_VALUE>Ja, vor dem Mauerfall mussten die Frauen im Osten bei den Männern vieles ertragen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2307" TIME_SLOT_REF2="ts2321" ANNOTATION_ID="a2563307"><ANNOTATION_VALUE>Die tranken und behandelten ihre Frauen schlecht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2321" TIME_SLOT_REF2="ts2344" ANNOTATION_ID="a2563308"><ANNOTATION_VALUE>Nach dem Mauerfall fanden sie nun im Westen liebe Männer und von da an gab es viele Trennungen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2344" TIME_SLOT_REF2="ts2359" ANNOTATION_ID="a2563310"><ANNOTATION_VALUE>Die Männer im Osten waren wütend auf uns, weil wir denen die Frauen stahlen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2359" TIME_SLOT_REF2="ts2387" ANNOTATION_ID="a2563313"><ANNOTATION_VALUE>So was macht man nicht. Man soll ja die Frauen nicht schlecht behandeln. Das müssen sich die Frauen nicht gefallen lassen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2387" TIME_SLOT_REF2="ts2408" ANNOTATION_ID="a2563319"><ANNOTATION_VALUE>Zum anderen, wer im Osten eine Arbeit hatte, war zufrieden mit allem.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2408" TIME_SLOT_REF2="ts2433" ANNOTATION_ID="a2563325"><ANNOTATION_VALUE>Wer keine Arbeit hatte, sagte dann, dass er die Mauer zurückhaben wollte.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2433" TIME_SLOT_REF2="ts2456" ANNOTATION_ID="a2563327"><ANNOTATION_VALUE>So leicht sind die zu durchschauen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2463" TIME_SLOT_REF2="ts2494" ANNOTATION_ID="a2563488"><ANNOTATION_VALUE>Im Westen ist es auch dasselbe, wer da vor dem Mauerfall Arbeit hatte und danach noch, war zufrieden damit.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2494" TIME_SLOT_REF2="ts2526" ANNOTATION_ID="a2973485"><ANNOTATION_VALUE>Wenn nicht, dann denken sie auch, es sei besser, man hätte die Mauer zurück.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2526" TIME_SLOT_REF2="ts2536" ANNOTATION_ID="a2563601"><ANNOTATION_VALUE>Das ist dasselbe bei beiden, also im Westen und Osten.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2538" TIME_SLOT_REF2="ts2554" ANNOTATION_ID="a2973494"><ANNOTATION_VALUE>Bei den Gehörlosen in der Slowakei ist das folgendermaßen:</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2554" TIME_SLOT_REF2="ts2586" ANNOTATION_ID="a2878377"><ANNOTATION_VALUE>Sie haben sich sehr auf den Sport konzentriert, sie wurden ja vom Staat gefördert.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2586" TIME_SLOT_REF2="ts2610" ANNOTATION_ID="a2563656"><ANNOTATION_VALUE>Es gab nicht viel Kulturelles dort. Alles drehte sich um Sport.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2610" TIME_SLOT_REF2="ts2621" ANNOTATION_ID="a2878638"><ANNOTATION_VALUE>Das hat mich stark beeinflusst.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2621" TIME_SLOT_REF2="ts2648" ANNOTATION_ID="a2563659"><ANNOTATION_VALUE>Als ich dann nach Berlin geflüchtet war, gab es nicht nur Sport, sondern ich konnte mich auch kulturell bei den Gehörlosen engagieren.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2648" TIME_SLOT_REF2="ts2665" ANNOTATION_ID="a2563661"><ANNOTATION_VALUE>Da gab es Puttrich und durch Jochen Muhs gab es viel Gehörlosenkultur.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2665" TIME_SLOT_REF2="ts2672" ANNOTATION_ID="a2706840"><ANNOTATION_VALUE>Ich lernte viel von ihnen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2672" TIME_SLOT_REF2="ts2682" ANNOTATION_ID="a2706841"><ANNOTATION_VALUE>Nun weiß ich mehr über die Kultur.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2682" TIME_SLOT_REF2="ts2695" ANNOTATION_ID="a2563697"><ANNOTATION_VALUE>Im Kommunismus hatten die Leute nur Sport im Kopf.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2695" TIME_SLOT_REF2="ts2702" ANNOTATION_ID="a2563701"><ANNOTATION_VALUE>Das sind die Unterschiede zwischen da und hier.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2702" TIME_SLOT_REF2="ts2741" ANNOTATION_ID="a2563704"><ANNOTATION_VALUE>Jetzt komme ich sogar dazu, mehr Kulturelles zu erleben als mit Sport, denn ich werde ja langsam zu alt dafür.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2772" TIME_SLOT_REF2="ts2788" ANNOTATION_ID="a2563756"><ANNOTATION_VALUE>Als ich damals Sport gemacht habe/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2788" TIME_SLOT_REF2="ts2819" ANNOTATION_ID="a2563758"><ANNOTATION_VALUE>Beim Fußball, wo alle gut spielten, war ich regelmäßig nur als Ersatzspieler dabei und ertrug es.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2819" TIME_SLOT_REF2="ts2848" ANNOTATION_ID="a2563852"><ANNOTATION_VALUE>(Damals wurden die Auswärtsspiele ja gefördert, nur deswegen war ich regelmäßig dabei.)</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2848" TIME_SLOT_REF2="ts2881" ANNOTATION_ID="a2563928"><ANNOTATION_VALUE>Heute gibt es viele starke Spieler in einer Mannschaft. Aber die sind dann nicht bereit, als Ersatzspieler auf der Bank zu sitzen. Dann gehen sie einfach.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2881" TIME_SLOT_REF2="ts2886" ANNOTATION_ID="a2563935"><ANNOTATION_VALUE>Dadurch kam es zu einem Spielerschwund.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2886" TIME_SLOT_REF2="ts2897" ANNOTATION_ID="a2563961"><ANNOTATION_VALUE>Auch wenn sie gut Fußball spielen konnten, waren sie dabei überheblich und hatten Probleme damit.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2897" TIME_SLOT_REF2="ts2917" ANNOTATION_ID="a2563976"><ANNOTATION_VALUE>Auch wenn ich ein guter Fußballspieler bin, muss ich die anderen Teamkollegen unterstützen und motivieren. Das ist gut für die Mannschaft.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2917" TIME_SLOT_REF2="ts2931" ANNOTATION_ID="a2973530"><ANNOTATION_VALUE>Aber bei denen war das nicht so, deshalb hatten sie diese Probleme.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2931" TIME_SLOT_REF2="ts2938" ANNOTATION_ID="a2563984"><ANNOTATION_VALUE>So oder so, jetzt haben die bei Comet Probleme.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2938" TIME_SLOT_REF2="ts2969" ANNOTATION_ID="a2563990"><ANNOTATION_VALUE>Bei Comet sind sichtbar 80% aller Spieler Ausländer und wenige deutsch.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2969" TIME_SLOT_REF2="ts3000" ANNOTATION_ID="a2973553"><ANNOTATION_VALUE>Die sind körperlich gut gerüstet, vor allem die jungen Türken.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Lexem_Geb&#xE4;rde_r_B" LINGUISTIC_TYPE_REF="L_tokens_right_left__finer_granularity" PARTICIPANT="ber-13"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts3" ANNOTATION_ID="a2296008_1"><ANNOTATION_VALUE>ICH1*</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts5" ANNOTATION_ID="a2295990_1"><ANNOTATION_VALUE>FAMILIE4*</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts7" ANNOTATION_ID="a2295993_1">