ID="a3289022"><ANNOTATION_VALUE>dann</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts356" TIME_SLOT_REF2="ts359" ANNOTATION_ID="a3289019"><ANNOTATION_VALUE>zu</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362" ANNOTATION_ID="a3289029"><ANNOTATION_VALUE>warm</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366" ANNOTATION_ID="a3289033"><ANNOTATION_VALUE>zu heiß</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370" ANNOTATION_ID="a3289037"><ANNOTATION_VALUE>zu</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374" ANNOTATION_ID="a3289044"><ANNOTATION_VALUE>fertig</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts376" TIME_SLOT_REF2="ts377" ANNOTATION_ID="a3289047"><ANNOTATION_VALUE>bisschen</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts378" TIME_SLOT_REF2="ts379" ANNOTATION_ID="a3289051"><ANNOTATION_VALUE>wart</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts382" TIME_SLOT_REF2="ts383" ANNOTATION_ID="a3289055"><ANNOTATION_VALUE>um</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts384" TIME_SLOT_REF2="ts385" ANNOTATION_ID="a3289058"><ANNOTATION_VALUE>fertig</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_A" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="ber-38"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts8" ANNOTATION_ID="a3233797"><ANNOTATION_VALUE>The topic is how to cook jam.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts19" ANNOTATION_ID="a3233803"><ANNOTATION_VALUE>Please try to do it exactly my way.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts26" ANNOTATION_ID="a3233804"><ANNOTATION_VALUE>First I do/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts36" ANNOTATION_ID="a3233807"><ANNOTATION_VALUE>I actually made some jam just recently.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts51" ANNOTATION_ID="a3233812"><ANNOTATION_VALUE>I picked a whole bucket full of blackberries.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts66" ANNOTATION_ID="a3233813"><ANNOTATION_VALUE>My hands turned red and purple while picking.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts66" TIME_SLOT_REF2="ts79" ANNOTATION_ID="a3233814"><ANNOTATION_VALUE>Back at home, I rinsed the berries a little bit in a bucket.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts91" ANNOTATION_ID="a3233815"><ANNOTATION_VALUE>Then you cook the berries in a big pot.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts98" ANNOTATION_ID="a3233816"><ANNOTATION_VALUE>After that, you take a sieve.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts134" ANNOTATION_ID="a3233817"><ANNOTATION_VALUE>I don’t want those small seeds of the blackberries in my jam; I don’t like that.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts134" TIME_SLOT_REF2="ts139" ANNOTATION_ID="a3233818"><ANNOTATION_VALUE>I want jam without any seeds.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts150" ANNOTATION_ID="a3233819"><ANNOTATION_VALUE>Therefore, everything has to go through the sieve.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts150" TIME_SLOT_REF2="ts157" ANNOTATION_ID="a3233820"><ANNOTATION_VALUE>So, I pour the berries into the sieve and firmly press them through it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts166" ANNOTATION_ID="a3233821"><ANNOTATION_VALUE>Now the thick juice drips out of the bottom of the sieve.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts166" TIME_SLOT_REF2="ts175" ANNOTATION_ID="a3233822"><ANNOTATION_VALUE>I do that until the whole bucket is empty.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts181" ANNOTATION_ID="a3233823"><ANNOTATION_VALUE>After it has boiled, I press it through the sieve.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts186" ANNOTATION_ID="a3233826"><ANNOTATION_VALUE>Keep doing that over and over again.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts186" TIME_SLOT_REF2="ts195" ANNOTATION_ID="a3233827"><ANNOTATION_VALUE>The pot fills up with that thick juice.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts205" ANNOTATION_ID="a3348145"><ANNOTATION_VALUE>You then take the so-called jam sugar.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts221" ANNOTATION_ID="a3348149"><ANNOTATION_VALUE>You take one kilogram of sugar per one kilogram of that thick fruit juice.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts236" ANNOTATION_ID="a3348167"><ANNOTATION_VALUE>That’s why it’s called 1:1.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts236" TIME_SLOT_REF2="ts253" ANNOTATION_ID="a3348168"><ANNOTATION_VALUE>There’s something like 2:1 or 3:1 as well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts264" ANNOTATION_ID="a3348179"><ANNOTATION_VALUE>The less sugar you use, the thinner and less tasty the jam will be.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts264" TIME_SLOT_REF2="ts287" ANNOTATION_ID="a3348181"><ANNOTATION_VALUE>With 1:1 the fruit taste is the most noticeable.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts298" ANNOTATION_ID="a3348182"><ANNOTATION_VALUE>So, my fruit to sugar ratio is 1:1.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts298" TIME_SLOT_REF2="ts305" ANNOTATION_ID="a3348217"><ANNOTATION_VALUE>Then I let the whole thing boil until it forms bubbles.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts320" ANNOTATION_ID="a3348218"><ANNOTATION_VALUE>First, you add the sugar and thoroughly mix it in, and then you bring it to a boil.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts320" TIME_SLOT_REF2="ts331" ANNOTATION_ID="a3348221"><ANNOTATION_VALUE>You then take it off the stove and fill the jam jars.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts343" ANNOTATION_ID="a3348223"><ANNOTATION_VALUE>You have to remove any stains from the side and the rim of the jars.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts353" ANNOTATION_ID="a3348261"><ANNOTATION_VALUE>You have to lightly shake the jars so that the jam drops to the bottom of the jars, and you can really pack them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts360" ANNOTATION_ID="a3348263"><ANNOTATION_VALUE>Then you put on the lids really tightly.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts360" TIME_SLOT_REF2="ts375" ANNOTATION_ID="a3348265"><ANNOTATION_VALUE>It still has to be hot, though.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts386" ANNOTATION_ID="a3348271"><ANNOTATION_VALUE>After waiting for a while, one turns the jars around. That’s it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__coarser_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_dependent_values" TIME_ALIGNABLE="false" CONSTRAINTS="Symbolic_Association"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_tokens_right_left__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__mouth__standard_orthography__coarser_granularity" TIME_ALIGNABLE="true"/><CONSTRAINT STEREOTYPE="Symbolic_Association" DESCRIPTION="1-1 association with a parent annotation"/></ANNOTATION_DOCUMENT>
