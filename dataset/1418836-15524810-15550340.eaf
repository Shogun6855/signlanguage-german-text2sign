_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts51" ANNOTATION_ID="a3218751"><ANNOTATION_VALUE>Ich habe einen ganzen Eimer voll schwarzer Brombeeren gepflückt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts66" ANNOTATION_ID="a3218699"><ANNOTATION_VALUE>Meine Hände sind vom wilden Pflücken ganz rot und lila geworden.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts66" TIME_SLOT_REF2="ts79" ANNOTATION_ID="a3218700"><ANNOTATION_VALUE>Zu Hause spüle ich die Beeren im Eimer ein bisschen durch.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts91" ANNOTATION_ID="a3218702"><ANNOTATION_VALUE>Dann kocht man die Beeren in einem Topf.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts98" ANNOTATION_ID="a3218703"><ANNOTATION_VALUE>Anschließend nimmt man ein Sieb.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts134" ANNOTATION_ID="a3218704"><ANNOTATION_VALUE>Ich möchte nicht diese kleinen Kerne der Brombeeren in der Marmelade haben, das mag ich nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts134" TIME_SLOT_REF2="ts139" ANNOTATION_ID="a3218705"><ANNOTATION_VALUE>Ich möchte kernfreie Marmelade.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts150" ANNOTATION_ID="a3218706"><ANNOTATION_VALUE>Darum muss alles durch das Sieb durch.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts150" TIME_SLOT_REF2="ts157" ANNOTATION_ID="a3218707"><ANNOTATION_VALUE>Ich schütte die Beeren in das Sieb und drücke sie kräftig durch.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts166" ANNOTATION_ID="a3218708"><ANNOTATION_VALUE>Der dickflüssige Saft tropft dann unten heraus.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts166" TIME_SLOT_REF2="ts175" ANNOTATION_ID="a3218709"><ANNOTATION_VALUE>Ich drehe alles durch das Sieb, bis der Eimer leer ist.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts181" ANNOTATION_ID="a3218710"><ANNOTATION_VALUE>Wenn es fertig gekocht ist, wird es durch das Sieb gedrückt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts186" ANNOTATION_ID="a3218730"><ANNOTATION_VALUE>So geht das immer weiter.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts186" TIME_SLOT_REF2="ts195" ANNOTATION_ID="a3218712"><ANNOTATION_VALUE>Der Topf wird immer voller mit der dickflüssigen Masse.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts205" ANNOTATION_ID="a3218713"><ANNOTATION_VALUE>Dann nimmt man den so genannten Gelierzucker.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts221" ANNOTATION_ID="a3218714"><ANNOTATION_VALUE>Man nimmt ein Kilo Zucker und ein Kilo von dem dicken Fruchtsaft.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts236" ANNOTATION_ID="a3218737"><ANNOTATION_VALUE>Darum sagt man auch 1 zu 1.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts236" TIME_SLOT_REF2="ts253" ANNOTATION_ID="a3218715"><ANNOTATION_VALUE>Es gibt auch 2 zu 1 oder 3 zu 1.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts264" ANNOTATION_ID="a3218716"><ANNOTATION_VALUE>Je weniger Zucker man nimmt, desto dünner und geschmackloser wird die Marmelade.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts264" TIME_SLOT_REF2="ts287" ANNOTATION_ID="a3218717"><ANNOTATION_VALUE>Bei 1 zu 1 schmeckt man die Frucht noch am besten heraus.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts298" ANNOTATION_ID="a3218718"><ANNOTATION_VALUE>Ich verrühre Früchte und Zucker also im Verhältnis 1 zu 1.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts298" TIME_SLOT_REF2="ts305" ANNOTATION_ID="a3218719"><ANNOTATION_VALUE>Dann koche ich alles, bis es anfängt zu blubbern.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts320" ANNOTATION_ID="a3218720"><ANNOTATION_VALUE>Zuerst kippt man den Zucker hinein und verrührt alles gut, dann lässt man es aufkochen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts320" TIME_SLOT_REF2="ts331" ANNOTATION_ID="a3218721"><ANNOTATION_VALUE>Dann nimmt man den Topf vom Herd und befüllt die Marmeladengläser.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts343" ANNOTATION_ID="a3218722"><ANNOTATION_VALUE>Flecken auf dem Glas und dem Rand muss man abwischen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts353" ANNOTATION_ID="a3218723"><ANNOTATION_VALUE>Man muss die Gläser ein bisschen schütteln, damit die Marmelade nac