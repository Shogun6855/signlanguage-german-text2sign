N TIME_SLOT_REF1="ts152" TIME_SLOT_REF2="ts157" ANNOTATION_ID="a2129724"><ANNOTATION_VALUE>Nein, dazu kann ich nichts sagen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts168" ANNOTATION_ID="a2129726"><ANNOTATION_VALUE>Ich weiß nichts über Diana.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts168" TIME_SLOT_REF2="ts182" ANNOTATION_ID="a2129733"><ANNOTATION_VALUE>Aber ich weiß, dass sie Königin von England war.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts182" TIME_SLOT_REF2="ts200" ANNOTATION_ID="a2676946"><ANNOTATION_VALUE>Aber mehr hat es mich halt nicht interessiert.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts200" TIME_SLOT_REF2="ts212" ANNOTATION_ID="a2904655"><ANNOTATION_VALUE>Das beschäftigt mich nicht so.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts260" TIME_SLOT_REF2="ts281" ANNOTATION_ID="a2129847"><ANNOTATION_VALUE>Damals war ich noch zu klein, um sie zu kennen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts294" ANNOTATION_ID="a2129853"><ANNOTATION_VALUE>Als das passiert ist, war ich so etwa #X Jahre alt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts294" TIME_SLOT_REF2="ts305" ANNOTATION_ID="a2129900"><ANNOTATION_VALUE>Aber als Erwachsener wusste ich natürlich Bescheid.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts642" TIME_SLOT_REF2="ts658" ANNOTATION_ID="a2130070"><ANNOTATION_VALUE>Ich habe es durch Gerüchte erfahren.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts658" TIME_SLOT_REF2="ts673" ANNOTATION_ID="a2130074"><ANNOTATION_VALUE>Es sei entweder ein Mordversuch gewesen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts683" ANNOTATION_ID="a2130077"><ANNOTATION_VALUE>Oder es war doch nur ein Unfall.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts688" ANNOTATION_ID="a2131861"><ANNOTATION_VALUE>Mehr weiß ich nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts688" TIME_SLOT_REF2="ts708" ANNOTATION_ID="a2677574"><ANNOTATION_VALUE>Ich hab mich nicht näher damit beschäftigt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts708" TIME_SLOT_REF2="ts719" ANNOTATION_ID="a2131872"><ANNOTATION_VALUE>So hab ich es halt erfahren.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts886" ANNOTATION_ID="a2132032"><ANNOTATION_VALUE>Bist du zur Trauerfeier gegangen?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts892" TIME_SLOT_REF2="ts917" ANNOTATION_ID="a2132054"><ANNOTATION_VALUE>Nein, ich meinte, ob er bei einer Gedenkfeier dort dabei war, aber war er ja nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1039" TIME_SLOT_REF2="ts1068" ANNOTATION_ID="a2132102"><ANNOTATION_VALUE>Aber wenn Diana nicht gestorben wäre, wäre die Welt durch sie dann viel besser geworden? Stellst du dir das so vor?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1127" TIME_SLOT_REF2="ts1140" ANNOTATION_ID="a2132157"><ANNOTATION_VALUE>Es könnte aber Afrika besser gehen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1140" TIME_SLOT_REF2="ts1157" ANNOTATION_ID="a2132160"><ANNOTATION_VALUE>Die haben ja Probleme mit der Nahrungsversorgung.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1166" TIME_SLOT_REF2="ts1169" ANNOTATION_ID="a2132173"><ANNOTATION_VALUE>Ja, das stimmt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1169" TIME_SLOT_REF2="ts1183" ANNOTATION_ID="a2132180"><ANNOTATION_VALUE>Ich habe mal erfahren, dass sie ein bisschen gebärden konnte.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1183" TIME_SLOT_REF2="ts1196" ANNOTATION_ID="a2132184"><ANNOTATION_VALUE>Diana hat Unterricht genommen und das gelernt, das hab ich mal erfahren.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1196" TIME_SLOT_REF2="ts1215" ANNOTATION_ID="a2132195"><ANNOTATION_VALUE>Aber woher das kam und warum, das weiß ich nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1215" TIME_SLOT_REF2="ts1227" ANNOTATION_ID="a2132198"><ANNOTATION_VALUE>Ich habe sie mal in einem Video gebärden sehen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1251" TIME_SLOT_REF2="ts1266" ANNOTATION_ID="a2132266"><ANNOTATION_VALUE>Klar, zwei Kinder.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1312" TIME_SLOT_REF2="ts1315" ANNOTATION_ID="a2132307"><ANNOTATION_VALUE>Keine Ahnung.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1350" TIME_SLOT_REF2="ts1361" ANNOTATION_ID="a2141668"><ANNOTATION_VALUE>Ich bin ja eh nicht so gut darin, alles über sie zu wissen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1362" TIME_SLOT_REF2="ts1366" ANNOTATION_ID="a2141995"><ANNOTATION_VALUE>Prinz Williams.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1366" TIME_SLOT_REF2="ts1377" ANNOTATION_ID="a2141998"><ANNOTATION_VALUE>Oder William, weiß nicht genau.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1397" TIME_SLOT_REF2="ts1399" ANNOTATION_ID="a2142002"><ANNOTATION_VALUE>Ah ja, das stimmt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1399" TIME_SLOT_REF2="ts1411" ANNOTATION_ID="a2142004"><ANNOTATION_VALUE>Prinz Charles William, habe ich recht?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1411" TIME_SLOT_REF2="ts1414" ANNOTATION_ID="a2142007"><ANNOTATION_VALUE>Der Name ist auffällig.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1415" TIME_SLOT_REF2="ts1423" ANNOTATION_ID="a2142009"><ANNOTATION_VALUE>In London.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1423" TIME_SLOT_REF2="ts1437" ANNOTATION_ID="a2142012"><ANNOTATION_VALUE>Mittendrin ist die Königin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1516" TIME_SLOT_REF2="ts1538" ANNOTATION_ID="a2142053"><ANNOTATION_VALUE>Bekannte Personen wie Queen Elisabeth kenne ich.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1538" TIME_SLOT_REF2="ts1553" ANNOTATION_ID="a2142058"><ANNOTATION_VALUE>Und diese Brüder, den jüngeren und den älteren.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1553" TIME_SLOT_REF2="ts1564" ANNOTATION_ID="a2142063"><ANNOTATION_VALUE>Die waren ja so präsent in den Medien.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1564" TIME_SLOT_REF2="ts1583" ANNOTATION_ID="a2142064"><ANNOTATION_VALUE>Aber dieser Charles William nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1583" TIME_SLOT_REF2="ts1593" ANNOTATION_ID="a2142067"><ANNOTATION_VALUE>Er lebt sozusagen zurückgezogen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1595" TIME_SLOT_REF2="ts1609" ANNOTATION_ID="a2142069"><ANNOTATION_VALUE>Ja, doch, es gibt auch andere Länder mit Königen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1609" TIME_SLOT_REF2="ts1616" ANNOTATION_ID="a2142070"><ANNOTATION_VALUE>Aber hier in Deutschland haben wir keinen König.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1616" TIME_SLOT_REF2="ts1630" ANNOTATION_ID="a2142072"><ANNOTATION_VALUE>Früher schon, aber jetzt nicht mehr.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1667" TIME_SLOT_REF2="ts1693" ANNOTATION_ID="a2677726"><ANNOTATION_VALUE>Aber es gibt im Süden auch Könige wie z.B. in Spanien oder Monaco.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1693" TIME_SLOT_REF2="ts1698" ANNOTATION_ID="a3042716"><ANNOTATION_VALUE>Gibt es noch mehr?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1698" TIME_SLOT_REF2="ts1707" ANNOTATION_ID="a3042718"><ANNOTATION_VALUE>Vor allem in Europa eben.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_A" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="ber-36"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts144" ANNOTATION_ID="a2692342"><ANNOTATION_VALUE>How interesting.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts144" TIME_SLOT_REF2="ts152" ANNOTATION_ID="a2692345"><ANNOTATION_VALUE>Shall I tell you something now?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts152" TIME_SLOT_REF2="ts157" ANNOTATION_ID="a2692350"><ANNOTATION_VALUE>No, I can't say something about this topic.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts168" ANNOTATION_ID="a2692351"><ANNOTATION_VALUE>I don't know anything about Diana.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts168" TIME_SLOT_REF2="ts182" ANNOTATION_ID="a2692352"><ANNOTATION_VALUE>But I know she was the queen of England.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts182" TIME_SLOT_REF2="ts200" ANNOTATION_ID="a2692353"><ANNOTATION_VALUE>But it didn't interest me that much.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts200" TIME_SLOT_REF2="ts212" ANNOTATION_ID="a2905005"><ANNOTATION_VALUE>That's not something I think about.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts260" TIME_SLOT_REF2="ts281" ANNOTATION_ID="a2692361"><ANNOTATION_VALUE>At that time I was too little to know her.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts294" ANNOTATION_ID="a2692367"><ANNOTATION_VALUE>I was like #X years old when all that happened.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts294" TIME_SLOT_REF2="ts305" ANNOTATION_ID="a2692368"><ANNOTATION_VALUE>But now as a grown up I sure know about all this.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts642" TIME_SLOT_REF2="ts658" ANNOTATION_ID="a2692524"><ANNOTATION_VALUE>I have been know it from rumors.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts658" TIME_SLOT_REF2="ts673" ANNOTATION_ID="a2692531"><ANNOTATION_VALUE>It either was murder, they said.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts683" ANNOTATION_ID="a2692532"><ANNOTATION_VALUE>Or it was an accident.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts688" ANNOTATION_ID="a2692533"><ANNOTATION_VALUE>I don't know anything else.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts688" TIME_SLOT_REF2="ts708" ANNOTATION_ID="a2692542"><ANNOTATION_VALUE>I didn't follow up on the topic.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts708" TIME_SLOT_REF2="ts719" ANNOTATION_ID="a2692547"><ANNOTATION_VALUE>That's how heard of it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts886" ANNOTATION_ID="a2692648"><ANNOTATION_VALUE>Did you go to the funeral?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts892" TIME_SLOT_REF2="ts917" ANNOTATION_ID="a2692650"><ANNOTATION_VALUE>No, I meant if he was there at the memorial but he just said he wasn't.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1039" TIME_SLOT_REF2="ts1068" ANNOTATION_ID="a2692802"><ANNOTATION_VALUE>Oh well, so you think if Diana was still alive the world would be a lot better or what?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1127" TIME_SLOT_REF2="ts1140" ANNOTATION_ID="a2692834"><ANNOTATION_VALUE>Africa could be better of now.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1140" TIME_SLOT_REF2="ts1157" ANNOTATION_ID="a2692841"><ANNOTATION_VALUE>They have problems with the food supply.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1166" TIME_SLOT_REF2="ts1169" ANNOTATION_ID="a2692842"><ANNOTATION_VALUE>Yes, that‘s right.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1169" TIME_SLOT_REF2="ts1183" ANNOTATION_ID="a2692852"><ANNOTATION_VALUE>I once heard that she could sign a little bit.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1183" TIME_SLOT_REF2="ts1196" ANNOTATION_ID="a2692859"><ANNOTATION_VALUE>Diana took lessons and learned signing, that’s what I heard of.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1196" TIME_SLOT_REF2="ts1215" ANNOTATION_ID="a2692860"><ANNOTATION_VALUE>But why and how, I don't know.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1215" TIME_SLOT_REF2="ts1227" ANNOTATION_ID="a2692863"><ANNOTATION_VALUE>I have seen her signing in a video once.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1251" TIME_SLOT_REF2="ts1266" ANNOTATION_ID="a2692872"><ANNOTATION_VALUE>Right, two kids.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1312" TIME_SLOT_REF2="ts1315" ANNOTATION_ID="a2692873"><ANNOTATION_VALUE>No idea.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1350" TIME_SLOT_REF2="ts1361" ANNOTATION_ID="a2692892"><ANNOTATION_VALUE>I am not great at knowing all about her.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1362" TIME_SLOT_REF2="ts1366" ANNOTATION_ID="a2692894"><ANNOTATION_VALUE>Prince Williams.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1366" TIME_SLOT_REF2="ts1377" ANNOTATION_ID="a2692896"><ANNOTATION_VALUE>Or William, I don't know.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1397" TIME_SLOT_REF2="ts1399" ANNOTATION_ID="a2692900"><ANNOTATION_VALUE>Yeah, that's true.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1399" TIME_SLOT_REF2="ts1411" ANNOTATION_ID="a2692901"><ANNOTATION_VALUE>Prince Charles William, isn't it?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1411" TIME_SLOT_REF2="ts1414" ANNOTATION_ID="a2692902"><ANNOTATION_VALUE>It‘s a remarkable name.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1415" TIME_SLOT_REF2="ts1423" ANNOTATION_ID="a2692904"><ANNOTATION_VALUE>In London.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1423" TIME_SLOT_REF2="ts1437" ANNOTATION_ID="a2692905"><ANNOTATION_VALUE>The queen is right in the center.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1516" TIME_SLOT_REF2="ts1538" ANNOTATION_ID="a2692916"><ANNOTATION_VALUE>I know famous ones like Queen Elizabeth.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1538" TIME_SLOT_REF2="ts1553" ANNOTATION_ID="a2692919"><ANNOTATION_VALUE>And those brothers, the younger and older one.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1553" TIME_SLOT_REF2="ts1564" ANNOTATION_ID="a2692920"><ANNOTATION_VALUE>They were really present in the media.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1564" TIME_SLOT_REF2="ts1583" ANNOTATION_ID="a2692921"><ANNOTATION_VALUE>But this Prince Charles William. I don't know him.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1583" TIME_SLOT_REF2="ts1593" ANNOTATION_ID="a2692923"><ANNOTATION_VALUE>He, so to say, lives secluded.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1595" TIME_SLOT_REF2="ts1609" ANNOTATION_ID="a2692925"><ANNOTATION_VALUE>Well yeah, there are other countries with kings as well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1609" TIME_SLOT_REF2="ts1616" ANNOTATION_ID="a2692926"><ANNOTATION_VALUE>But in Germany we don't have a king.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1616" TIME_SLOT_REF2="ts1630" ANNOTATION_ID="a2692927"><ANNOTATION_VALUE>We had one in the past, but not anymore.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1667" TIME_SLOT_REF2="ts1693" ANNOTATION_ID="a2692933"><ANNOTATION_VALUE>But there are also some kings in the south like Spain or Monaco.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1693" TIME_SLOT_REF2="ts1698" ANNOTATION_ID="a3129043"><ANNOTATION_VALUE>Are there more?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1698" TIME_SLOT_REF2="ts1707" ANNOTATION_ID="a3129044"><ANNOTATION_VALUE>Mainly in Europe.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></