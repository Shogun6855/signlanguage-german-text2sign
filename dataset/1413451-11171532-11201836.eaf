="a2809749"><ANNOTATION_VALUE>früher</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts916" TIME_SLOT_REF2="ts917" ANNOTATION_ID="a2809753"><ANNOTATION_VALUE>jetzt</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts918" TIME_SLOT_REF2="ts919" ANNOTATION_ID="a2809778"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts922" TIME_SLOT_REF2="ts923" ANNOTATION_ID="a2809771"><ANNOTATION_VALUE>deshalb</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Moderator" LINGUISTIC_TYPE_REF="L_text__finer_granularity" PARTICIPANT="ber-mod-1"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts9" ANNOTATION_ID="a2838384"><ANNOTATION_VALUE>Hattest du auch traurige Erinnerungen, zum Beispiel wie bei ihm mit seinem Vater?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts269" ANNOTATION_ID="a2856794"><ANNOTATION_VALUE>Liegt er bis jetzt noch im Koma?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts403" ANNOTATION_ID="a2859150"><ANNOTATION_VALUE>Aber schwerhörig zu sein und ein CI zu haben ist doch dasselbe.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts418" TIME_SLOT_REF2="ts431" ANNOTATION_ID="a2456325"><ANNOTATION_VALUE>CI-Träger können es auch, es müssen nicht nur die Schwerhörigen sein.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts519" ANNOTATION_ID="a2861792"><ANNOTATION_VALUE>Wie sieht dein typischer Alltag aus? Ein ganzer Tag, von morgens bis abends?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts901" ANNOTATION_ID="a2856811"><ANNOTATION_VALUE>Spielst du auch Fußball?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_Mod" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="ber-mod-1"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts9" ANNOTATION_ID="a2950784"><ANNOTATION_VALUE>Did you experience anything sad, as well? Something like he experienced with his dad?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts269" ANNOTATION_ID="a2950803"><ANNOTATION_VALUE>Is he still in a coma?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts403" ANNOTATION_ID="a2950812"><ANNOTATION_VALUE>But being hard of hearing and having a CI is the same thing.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts418" TIME_SLOT_REF2="ts431" ANNOTATION_ID="a2950815"><ANNOTATION_VALUE>People with a CI are able to do so, too. It's not just the hard of hearing.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts519" ANNOTATION_ID="a2951391"><ANNOTATION_VALUE>What does your typical day look like? An entire day from morning to evening?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts901" ANNOTATION_ID="a2951538"><ANNOTATION_VALUE>Do you play soccer, as well?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__coarser_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_dependent_values" TIME_ALIGNABLE="false" CONSTRAINTS="Symbolic_Association"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_tokens_right_left__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__mouth__standard_orthography__coarser_granularity" TIME_ALIGNABLE="true"/><CONSTRAINT STEREOTYPE="Symbolic_Association" DESCRIPTION="1-1 association with a parent annotation"/></ANNOTATION_DOCUMENT>
