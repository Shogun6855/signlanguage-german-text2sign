OT TIME_SLOT_ID="ts898" TIME_VALUE="178140"/><TIME_SLOT TIME_SLOT_ID="ts899" TIME_VALUE="178260"/><TIME_SLOT TIME_SLOT_ID="ts900" TIME_VALUE="178340"/><TIME_SLOT TIME_SLOT_ID="ts901" TIME_VALUE="178380"/><TIME_SLOT TIME_SLOT_ID="ts902" TIME_VALUE="178460"/><TIME_SLOT TIME_SLOT_ID="ts903" TIME_VALUE="178600"/><TIME_SLOT TIME_SLOT_ID="ts904" TIME_VALUE="178820"/><TIME_SLOT TIME_SLOT_ID="ts905" TIME_VALUE="178900"/><TIME_SLOT TIME_SLOT_ID="ts906" TIME_VALUE="179080"/><TIME_SLOT TIME_SLOT_ID="ts907" TIME_VALUE="179180"/><TIME_SLOT TIME_SLOT_ID="ts908" TIME_VALUE="179340"/><TIME_SLOT TIME_SLOT_ID="ts909" TIME_VALUE="179520"/><TIME_SLOT TIME_SLOT_ID="ts910" TIME_VALUE="179760"/><TIME_SLOT TIME_SLOT_ID="ts911" TIME_VALUE="179780"/><TIME_SLOT TIME_SLOT_ID="ts912" TIME_VALUE="179880"/><TIME_SLOT TIME_SLOT_ID="ts913" TIME_VALUE="179940"/><TIME_SLOT TIME_SLOT_ID="ts914" TIME_VALUE="180060"/><TIME_SLOT TIME_SLOT_ID="ts915" TIME_VALUE="180240"/><TIME_SLOT TIME_SLOT_ID="ts916" TIME_VALUE="180340"/><TIME_SLOT TIME_SLOT_ID="ts917" TIME_VALUE="180540"/><TIME_SLOT TIME_SLOT_ID="ts918" TIME_VALUE="180880"/><TIME_SLOT TIME_SLOT_ID="ts919" TIME_VALUE="181280"/><TIME_SLOT TIME_SLOT_ID="ts920" TIME_VALUE="181380"/><TIME_SLOT TIME_SLOT_ID="ts921" TIME_VALUE="181600"/><TIME_SLOT TIME_SLOT_ID="ts922" TIME_VALUE="181960"/><TIME_SLOT TIME_SLOT_ID="ts923" TIME_VALUE="182340"/><TIME_SLOT TIME_SLOT_ID="ts924" TIME_VALUE="183080"/></TIME_ORDER><TIER TIER_ID="Deutsche_&#xDC;bersetzung_A" LINGUISTIC_TYPE_REF="L_text__finer_granularity" PARTICIPANT="ber-36"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts12" ANNOTATION_ID="a2838388"><ANNOTATION_VALUE>Was Trauriges?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts25" ANNOTATION_ID="a2838389"><ANNOTATION_VALUE>Eigentlich habe ich bisher in meinem Leben nichts allzu Trauriges erlebt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts43" ANNOTATION_ID="a2838391"><ANNOTATION_VALUE>Vor kurzem ist was passiert, so ungefähr vor einem Monat, nein, vor zwei, drei Wochen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts57" ANNOTATION_ID="a2856780"><ANNOTATION_VALUE>Vor drei Wochen habe ich erfahren, dass mein Opa ins Krankenhaus eingeliefert worden ist.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts86" ANNOTATION_ID="a2838392"><ANNOTATION_VALUE>Anfangs war es nicht schlimm, es war eigentlich harmlos, aber er kam trotzdem um sicherzugehen ins Krankenhaus.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts86" TIME_SLOT_REF2="ts109" ANNOTATION_ID="a2838398"><ANNOTATION_VALUE>Aber eine Woche später ist doch was passiert, er lag plötzlich im Koma.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts134" ANNOTATION_ID="a2856782"><ANNOTATION_VALUE>Als ich ihn zum ersten Mal im Koma da liegen sah, waren sein Gesicht und seine Beine ganz starr.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts134" TIME_SLOT_REF2="ts149" ANNOTATION_ID="a2856783"><ANNOTATION_VALUE>Als ich ihn zum ersten Mal so sah, habe ich mich schlecht gefühlt, das war schon krass.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts173" ANNOTATION_ID="a2854342"><ANNOTATION_VALUE>Mein Opa war schon einundachtzig Jahre alt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts198" ANNOTATION_ID="a2856787"><ANNOTATION_VALUE>Der Grund für seine aussichtslose Situation war, dass er Probleme mit dem Herzen hatte und sein Kreislauf erschöpft war und so weiter.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts198" TIME_SLOT_REF2="ts217" ANNOTATION_ID="a2856788"><ANNOTATION_VALUE>Er hatte so viele Probleme, aber wir hoffen einfach, dass er bald aufwacht und überlebt.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts234" ANNOTATION_ID="a2854372"><ANNOTATION_VALUE>Sie sagten, dass er zu 50 Prozent sterben und zu 50 Prozent überleben könnte.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts234" TIME_SLOT_REF2="ts259" ANNOTATION_ID="a2856797"><ANNOTATION_VALUE>Deshalb würde ich sagen, dass dies bis jetzt das Traurigste war.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts265" ANNOTATION_ID="a2856800"><ANNOTATION_VALUE>Und plötzlich/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts276" ANNOTATION_ID="a2856802"><ANNOTATION_VALUE>Ja, ich habe es ja erst vor Kurzem erfahren, dass es passiert ist.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts276" TIME_SLOT_REF2="ts305" ANNOTATION_ID="a2856808"><ANNOTATION_VALUE>Aber was für mich auch noch traurig ist, ist zum Beispiel, dass meine Eltern überhaupt nicht gebärden können.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts316" ANNOTATION_ID="a2856809"><ANNOTATION_VALUE>Darüber bin ich traurig.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts316" TIME_SLOT_REF2="ts319" ANNOTATION_ID="a2859142"><ANNOTATION_VALUE>Sonst gibt es nichts.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts338" ANNOTATION_ID="a2859144"><ANNOTATION_VALUE>Ich wünschte, ich wäre schwerhörig.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts338" TIME_SLOT_REF2="ts369" ANNOTATION_ID="a2859146"><ANNOTATION_VALUE>Der Grund dafür ist, dass ich sowohl mit Gehörlosen gebärden und Späße machen, als auch mit den Hörenden sprechen könnte.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts376" ANNOTATION_ID="a2859147"><ANNOTATION_VALUE>Da könnte ich zwischen den Sprachen wechseln.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts376" TIME_SLOT_REF2="ts387" ANNOTATION_ID="a2859148"><ANNOTATION_VALUE>Es gibt einige Schwerhörige, die das gut hinbekommen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts400" ANNOTATION_ID="a2859149"><ANNOTATION_VALUE>Für die ist das schön, ich kann das nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts402" TIME_SLOT_REF2="ts422" ANNOTATION_ID="a2859151"><ANNOTATION_VALUE>Nein, ich meine damit, dass sie einfach sprechen können.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts441" ANNOTATION_ID="a2859154"><ANNOTATION_VALUE>Na ja, ich war zu faul fürs Hören und ich/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts454" ANNOTATION_ID="a2859156"><ANNOTATION_VALUE>Aber es gibt einige, die können mit dem CI nichts wahrnehmen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts454" TIME_SLOT_REF2="ts473" ANNOTATION_ID="a2859159"><ANNOTATION_VALUE>Das ist verschieden: Einige können was hören, ich nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts482" ANNOTATION_ID="a2859161"><ANNOTATION_VALUE>Da muss man sich entscheiden.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts482" TIME_SLOT_REF2="ts497" ANNOTATION_ID="a2859176"><ANNOTATION_VALUE>Man weiß vorher nicht, ob das Implantat was bringt, das ist klar.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts508" ANNOTATION_ID="a2859177"><ANNOTATION_VALUE>Wenn du das CI ausprobierst, meinst du, dass es gelingt? Wohl eher nicht.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts510" TIME_SLOT_REF2="ts513" ANNOTATION_ID="a2861798"><ANNOTATION_VALUE>Alltag?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts514" TIME_SLOT_REF2="ts524" ANNOTATION_ID="a2861805"><ANNOTATION_VALUE>Ach so, wie ich so lebe.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts524" TIME_SLOT_REF2="ts539" ANNOTATION_ID="a2861813"><ANNOTATION_VALUE>Na ja, ich war ein Jahr lang arbeitslos.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts550" ANNOTATION_ID="a2861818"><ANNOTATION_VALUE>Da war das ein bisschen anders.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts550" TIME_SLOT_REF2="ts557" ANNOTATION_ID="a2861819"><ANNOTATION_VALUE>Was habe ich da so erlebt?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts580" ANNOTATION_ID="a2861843"><ANNOTATION_VALUE>In Essen war es bei mir so, dass ich zum Beispiel am Wochenende regelmäßig ein Spiel hatte und früh aufstehen musste.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts580" TIME_SLOT_REF2="ts593" ANNOTATION_ID="a2861849"><ANNOTATION_VALUE>Ich verschlief typischerweise und stand erst um 12 Uhr auf.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts610" ANNOTATION_ID="a2861865"><ANNOTATION_VALUE>Ich fragte dann, was wir machen sollten und wir sind einfach zum Einkaufen in die Stadt gegangen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts610" TIME_SLOT_REF2="ts637" ANNOTATION_ID="a2862856"><ANNOTATION_VALUE>Klamotten einkaufen war wichtig, denn wir brauchten für die Party am Abend was zum anziehen, das musste man vorher planen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts666" ANNOTATION_ID="a2863772"><ANNOTATION_VALUE>Aus Langeweile gingen wir auch oft ins Casino, wo wir beim Spielen erfolgreich waren und gewannen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts666" TIME_SLOT_REF2="ts681" ANNOTATION_ID="a2863779"><ANNOTATION_VALUE>Nach dem Spielen feierten wir die ganze Nacht in der Disco bis in den frühen Morgen, dann gingen wir dann irgendwann schlafen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts692" ANNOTATION_ID="a2863781"><ANNOTATION_VALUE>In Essen lieft das ganz oft so.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts692" TIME_SLOT_REF2="ts699" ANNOTATION_ID="a2863786"><ANNOTATION_VALUE>Aber jetzt ist das nicht mehr so.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts724" ANNOTATION_ID="a2863790"><ANNOTATION_VALUE>Ich bin jetzt in #Name1 zu Hause, da ist das anders.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts724" TIME_SLOT_REF2="ts737" ANNOTATION_ID="a2863793"><ANNOTATION_VALUE>Ich treffe mich viel weniger mit Gehörlosen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts737" TIME_SLOT_REF2="ts764" ANNOTATION_ID="a2863794"><ANNOTATION_VALUE>Die einen arbeiten, einige eher weniger und andere sind arbeitslos, aber mit denen brauche ich mich auch nicht treffen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts764" TIME_SLOT_REF2="ts800" ANNOTATION_ID="a2863831"><ANNOTATION_VALUE>Meistens fahre ich weiter weg, um Freunde zu treffen, zum Beispiel nach Halle, Hannover, nach Hamburg oder Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts800" TIME_SLOT_REF2="ts822" ANNOTATION_ID="a2863836"><ANNOTATION_VALUE>Die Zugfahrten sind dann sehr anstrengend, weil wir uns treffen und uns bis abends unterhalten, aber dann muss ich auch schon wieder zurück, das ist mühsam.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts822" TIME_SLOT_REF2="ts835" ANNOTATION_ID="a2863843"><ANNOTATION_VALUE>Machmal übernachte ich auch bei denen, das kommt auch vor.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts835" TIME_SLOT_REF2="ts840" ANNOTATION_ID="a2863849"><ANNOTATION_VALUE>Hm, und sonst?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts840" TIME_SLOT_REF2="ts863" ANNOTATION_ID="a2863898"><ANNOTATION_VALUE>Meistens, wenn ein Fußballspiel läuft, dann bin ich so gebannt, dass es das Einzige ist, was mir in dem Moment wichtig ist.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts876" ANNOTATION_ID="a2863902"><ANNOTATION_VALUE>Bei Fußballspielen zuzuschauen, ist mir sehr wichtig.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts876" TIME_SLOT_REF2="ts896" ANNOTATION_ID="a2863922"><ANNOTATION_VALUE>Ich liebe Fußball, das habe ich im Blut, vor allem bei wichtigen Spielen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts911" ANNOTATION_ID="a2863923"><ANNOTATION_VALUE>Ja, ich spielte auch Fußball.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts911" TIME_SLOT_REF2="ts924" ANNOTATION_ID="a2863924"><ANNOTATION_VALUE>Früher, ja, aber jetzt habe ich aufgehört und spiele nicht mehr.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_A" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="ber-36"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts12" ANNOTATION_ID="a2950785"><ANNOTATION_VALUE>Something sad?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts25" ANNOTATION_ID="a2950786"><ANNOTATION_VALUE>Well, actually I haven't experienced anything too sad so far.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts43" ANNOTATION_ID="a2950787"><ANNOTATION_VALUE>Recently something happened - approximately a month, no, two or three weeks ago.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts57" ANNOTATION_ID="a2950788"><ANNOTATION_VALUE>Three weeks ago, I learned that my grandpa had been hospitalized.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts86" ANNOTATION_ID="a2950789"><ANNOTATION_VALUE>In the beginning, it wasn't anything serious. Actually, it was quite harmless, but he was hospitalized, nonetheless - just in case.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts86" TIME_SLOT_REF2="ts109" ANNOTATION_ID="a2950791"><ANNOTATION_VALUE>But a week later, something actually happened. All of a sudden, he slipped into a coma.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts134" ANNOTATION_ID="a2950792"><ANNOTATION_VALUE>When I first saw him in that condition, his face and legs were very stiff.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts134" TIME_SLOT_REF2="ts149" ANNOTATION_ID="a2950793"><ANNOTATION_VALUE>I felt really bad when I first saw him like that. It was intense.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts173" ANNOTATION_ID="a2950794"><ANNOTATION_VALUE>My grandpa is 81 years old.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts198" ANNOTATION_ID="a2950795"><ANNOTATION_VALUE>The reason for his hopeless condition was that he had some problems with his heart, and that his circulatory system was exhausted, and some other things, as well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts198" TIME_SLOT_REF2="ts217" ANNOTATION_ID="a2950797"><ANNOTATION_VALUE>He had so many problems. Yet, we still hope that he will survive and wake up soon.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts234" ANNOTATION_ID="a2950799"><ANNOTATION_VALUE>They told us that there is fifty-fifty chance for him to survive.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts234" TIME_SLOT_REF2="ts259" ANNOTATION_ID="a2950801"><ANNOTATION_VALUE>So I would say that this has been my saddest experience so far.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts265" ANNOTATION_ID="a2950802"><ANNOTATION_VALUE>And suddenly/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts276" ANNOTATION_ID="a2950804"><ANNOTATION_VALUE>Yes, I just heard about it recently.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts276" TIME_SLOT_REF2="ts305" ANNOTATION_ID="a2950805"><ANNOTATION_VALUE>Yet, something else that makes me sad is that my parents cannot sign at all.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts316" ANNOTATION_ID="a2950806"><ANNOTATION_VALUE>That makes me sad.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts316" TIME_SLOT_REF2="ts319" ANNOTATION_ID="a2950807"><ANNOTATION_VALUE>That's it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts369" ANNOTATION_ID="a2950808"><ANNOTATION_VALUE>I wish I was hard of hearing, because I would be able to sign and joke around with deaf people, but at the same time, I would be able to talk to hearing people.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts376" ANNOTATION_ID="a2950809"><ANNOTATION_VALUE>I would be able to switch between the two languages.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts376" TIME_SLOT_REF2="ts387" ANNOTATION_ID="a2950810"><ANNOTATION_VALUE>There are some hard of hearing people who are really good at it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts400" ANNOTATION_ID="a2950811"><ANNOTATION_VALUE>That's great for them; I'm not able to do so.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts402" TIME_SLOT_REF2="ts422" ANNOTATION_ID="a2950813"><ANNOTATION_VALUE>No, what I mean is that they can easily speak.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts441" ANNOTATION_ID="a2950814"><ANNOTATION_VALUE>Well, I was too lazy to hear, and I/</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts454" ANNOTATION_ID="a2950816"><ANNOTATION_VALUE>Yet, there are some that cannot hear anything with the CI.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts454" TIME_SLOT_REF2="ts473" ANNOTATION_ID="a2950817"><ANNOTATION_VALUE>It varies: some can hear well, others, like myself, can't.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts482" ANNOTATION_ID="a2950818"><ANNOTATION_VALUE>You have to make a decision about it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts482" TIME_SLOT_REF2="ts497" ANNOTATION_ID="a2950819"><ANNOTATION_VALUE>You cannot know beforehand whether the implant will work or not. That's for sure.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts508" ANNOTATION_ID="a2952344"><ANNOTATION_VALUE>If you tried it, would you actually think that it works? Probably not.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts510" TIME_SLOT_REF2="ts513" ANNOTATION_ID="a2951393"><ANNOTATION_VALUE>Everyday life?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts514" TIME_SLOT_REF2="ts524" ANNOTATION_ID="a2951394"><ANNOTATION_VALUE>Ah, right. What my life looks like.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts524" TIME_SLOT_REF2="ts539" ANNOTATION_ID="a2951396"><ANNOTATION_VALUE>Well, I was unemployed for a year.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts550" ANNOTATION_ID="a2951398"><ANNOTATION_VALUE>My life was different then.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts550" TIME_SLOT_REF2="ts557" ANNOTATION_ID="a2951400"><ANNOTATION_VALUE>What did I experience during that time?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts580" ANNOTATION_ID="a2951407"><ANNOTATION_VALUE>For example, while being in Essen, I regularly had to get up early on the weekends to go to soccer games.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts580" TIME_SLOT_REF2="ts593" ANNOTATION_ID="a2951409"><ANNOTATION_VALUE>I typically overslept and got up at about twelve o'clock.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts610" ANNOTATION_ID="a2951415"><ANNOTATION_VALUE>Then I would ask what our plans were for the day, and we simply went downtown to shop.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts610" TIME_SLOT_REF2="ts637" ANNOTATION_ID="a2951419"><ANNOTATION_VALUE>Buying new clothes was quite important, because we always needed something new to wear for the parties in the evening. We had to plan ahead.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts666" ANNOTATION_ID="a2951421"><ANNOTATION_VALUE>Because we were bored, we often went to the casino, as well. We were quite successful with the gambling and won regularly.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts666" TIME_SLOT_REF2="ts681" ANNOTATION_ID="a2951429"><ANNOTATION_VALUE>After gambling, we used to party at the club all night long until early in the morning. Then we went to bed.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts692" ANNOTATION_ID="a2951475"><ANNOTATION_VALUE>That’s what it was usually like in Essen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts692" TIME_SLOT_REF2="ts724" ANNOTATION_ID="a2951476"><ANNOTATION_VALUE>But now that I live in #Name1, it is different.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts724" TIME_SLOT_REF2="ts737" ANNOTATION_ID="a2951496"><ANNOTATION_VALUE>I rarely meet up with other deaf people.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts737" TIME_SLOT_REF2="ts764" ANNOTATION_ID="a2951499"><ANNOTATION_VALUE>Some work, some work less, and some others are unemployed, but what would be the use of meeting those.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts764" TIME_SLOT_REF2="ts800" ANNOTATION_ID="a2951501"><ANNOTATION_VALUE>Most of the time, I drive further away to meet friends, for example to Halle, Hannover, Hamburg, or Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts800" TIME_SLOT_REF2="ts822" ANNOTATION_ID="a2951504"><ANNOTATION_VALUE>The train rides are really tiring. We meet up and talk all day until the evening, but then I have to go back home - that's exhausting.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts822" TIME_SLOT_REF2="ts835" ANNOTATION_ID="a2951506"><ANNOTATION_VALUE>I sometimes sleep over at their places; that happens every once in a while.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts835" TIME_SLOT_REF2="ts840" ANNOTATION_ID="a2951507"><ANNOTATION_VALUE>Anything else?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts840" TIME_SLOT_REF2="ts863" ANNOTATION_ID="a2951516"><ANNOTATION_VALUE>Usually, when there's a soccer game on, I am completely spellbound, and it's the only thing that matters to me in that moment.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts876" ANNOTATION_ID="a2951520"><ANNOTATION_VALUE>Watching soccer means a lot to me.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts876" TIME_SLOT_REF2="ts896" ANNOTATION_ID="a2951537"><ANNOTATION_VALUE>I love soccer. It's in my genes, especially when it's an important match.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts911" ANNOTATION_ID="a2951539"><ANNOTATION_VALUE>Yes, I used to play soccer.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts911" TIME_SLOT_REF2="ts924" ANNOTATION_ID="a2951540"><ANNOTATION_VALUE>I played soccer in the past, but now I have stopped.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION>