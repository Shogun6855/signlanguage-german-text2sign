OTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2800" TIME_SLOT_REF2="ts2801" ANNOTATION_ID="a2431630"><ANNOTATION_VALUE>sehr</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2802" TIME_SLOT_REF2="ts2803" ANNOTATION_ID="a2432100"><ANNOTATION_VALUE>zufrieden</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2809" TIME_SLOT_REF2="ts2810" ANNOTATION_ID="a2432104"><ANNOTATION_VALUE>als</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2811" TIME_SLOT_REF2="ts2812" ANNOTATION_ID="a2432106"><ANNOTATION_VALUE>dokumenten</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2813" TIME_SLOT_REF2="ts2814" ANNOTATION_ID="a2432127"><ANNOTATION_VALUE>management</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2815" TIME_SLOT_REF2="ts2816" ANNOTATION_ID="a2432112"><ANNOTATION_VALUE>für</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2817" TIME_SLOT_REF2="ts2818" ANNOTATION_ID="a2432108"><ANNOTATION_VALUE>archiv</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2819" TIME_SLOT_REF2="ts2820" ANNOTATION_ID="a2432157"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2824" TIME_SLOT_REF2="ts2825" ANNOTATION_ID="a2432147"><ANNOTATION_VALUE>viel</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2826" TIME_SLOT_REF2="ts2831" ANNOTATION_ID="a2432149"><ANNOTATION_VALUE>aufgabe</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2833" TIME_SLOT_REF2="ts2834" ANNOTATION_ID="a2432154"><ANNOTATION_VALUE>mit</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2839" TIME_SLOT_REF2="ts2842" ANNOTATION_ID="a2431679"><ANNOTATION_VALUE>arbeitsassistenz</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2851" TIME_SLOT_REF2="ts2854" ANNOTATION_ID="a2431992"><ANNOTATION_VALUE>besprechung</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2855" TIME_SLOT_REF2="ts2858" ANNOTATION_ID="a2431989"><ANNOTATION_VALUE>dolmetscher</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2861" TIME_SLOT_REF2="ts2862" ANNOTATION_ID="a2432164"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2864" TIME_SLOT_REF2="ts2865" ANNOTATION_ID="a2432160"><ANNOTATION_VALUE>bis</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2866" TIME_SLOT_REF2="ts2867" ANNOTATION_ID="a2432094"><ANNOTATION_VALUE>schon</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2868" TIME_SLOT_REF2="ts2871" ANNOTATION_ID="a2432029"><ANNOTATION_VALUE>zweiunddreißig</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2872" TIME_SLOT_REF2="ts2873" ANNOTATION_ID="a3203322"><ANNOTATION_VALUE>jahr</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2874" TIME_SLOT_REF2="ts2875" ANNOTATION_ID="a2432092"><ANNOTATION_VALUE>deshalb</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2878" TIME_SLOT_REF2="ts2881" ANNOTATION_ID="a2432085"><ANNOTATION_VALUE>arbeiten</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2883" TIME_SLOT_REF2="ts2884" ANNOTATION_ID="a2432098"><ANNOTATION_VALUE>wohl</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2887" TIME_SLOT_REF2="ts2890" ANNOTATION_ID="a2432185"><ANNOTATION_VALUE>krankschreiben</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2893" TIME_SLOT_REF2="ts2894" ANNOTATION_ID="a3965677"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2895" TIME_SLOT_REF2="ts2898" ANNOTATION_ID="a2432186"><ANNOTATION_VALUE>krankschreiben</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2899" TIME_SLOT_REF2="ts2900" ANNOTATION_ID="a3965674"><ANNOTATION_VALUE>[MG]</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_B" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="ber-15"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts20" ANNOTATION_ID="a2890887"><ANNOTATION_VALUE>I was born hearing. I lost my hearing when I was little.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts44" ANNOTATION_ID="a2890888"><ANNOTATION_VALUE>I became deaf at the age of one and a half because I had meningitis.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts63" ANNOTATION_ID="a2890892"><ANNOTATION_VALUE>Later on I started kindergarten in Neckar/ </ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts77" ANNOTATION_ID="a3911329"><ANNOTATION_VALUE>In Neckargemünd close to Heidelberg.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts97" ANNOTATION_ID="a3378836"><ANNOTATION_VALUE>I was already five years old when first joining the day-care with other children.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts114" ANNOTATION_ID="a2890894"><ANNOTATION_VALUE>I didn't know how to sign before that.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts144" ANNOTATION_ID="a2890908"><ANNOTATION_VALUE>I learned many signs there and got to know different kids and how to interact with them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts154" ANNOTATION_ID="a2890909"><ANNOTATION_VALUE>I was there until I was seven.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts180" ANNOTATION_ID="a2890911"><ANNOTATION_VALUE>Then I went to the school for the deaf in Heidelberg.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts206" ANNOTATION_ID="a2893839"><ANNOTATION_VALUE>Between the ages of five and seven I slowly started to learn sign language.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts215" ANNOTATION_ID="a2893840"><ANNOTATION_VALUE>Then I gradually got better in Heidelberg.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts225" ANNOTATION_ID="a3741251"><ANNOTATION_VALUE>Most of the time I signed. I didn’t like to speak.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts242" ANNOTATION_ID="a2893842"><ANNOTATION_VALUE>The teachers spoke all the time and only used the oral method.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts242" TIME_SLOT_REF2="ts247" ANNOTATION_ID="a2893844"><ANNOTATION_VALUE>I only sat there and nodded my head.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts252" ANNOTATION_ID="a2893846"><ANNOTATION_VALUE>Using sign language wasn’t allowed.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts252" TIME_SLOT_REF2="ts259" ANNOTATION_ID="a2893847"><ANNOTATION_VALUE>Otherwise you were punished.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts276" ANNOTATION_ID="a2893858"><ANNOTATION_VALUE>I adjusted to the fact that the classes were in spoken language. I wrote and talked.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts276" TIME_SLOT_REF2="ts289" ANNOTATION_ID="a2893859"><ANNOTATION_VALUE>It was a hard time.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts308" ANNOTATION_ID="a2893871"><ANNOTATION_VALUE>I switched to vocational school by age 15.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts308" TIME_SLOT_REF2="ts319" ANNOTATION_ID="a2893877"><ANNOTATION_VALUE>I started an apprenticeship as a drafter there.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts354" ANNOTATION_ID="a2893899"><ANNOTATION_VALUE>I had to return to school every Monday. I constantly drove back and forth.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts354" TIME_SLOT_REF2="ts369" ANNOTATION_ID="a2893901"><ANNOTATION_VALUE>I stayed in boarding school Monday through Friday.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts374" ANNOTATION_ID="a2893902"><ANNOTATION_VALUE>I went home for the weekends.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts374" TIME_SLOT_REF2="ts383" ANNOTATION_ID="a2893908"><ANNOTATION_VALUE>On Mondays I returned to school.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts398" ANNOTATION_ID="a2893913"><ANNOTATION_VALUE>We went to vocational school once a week.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts398" TIME_SLOT_REF2="ts419" ANNOTATION_ID="a2893921"><ANNOTATION_VALUE>They, too, only used spoken language in vocational school.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts428" ANNOTATION_ID="a2893926"><ANNOTATION_VALUE>We used a lot of gestures and facial expressions, but we had to speak along with it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts428" TIME_SLOT_REF2="ts431" ANNOTATION_ID="a2893933"><ANNOTATION_VALUE>We had to express ourselves mainly orally.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts442" ANNOTATION_ID="a2893936"><ANNOTATION_VALUE>I stayed there until I graduated.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts442" TIME_SLOT_REF2="ts462" ANNOTATION_ID="a2893939"><ANNOTATION_VALUE>Then I became a top-ranking athlete.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts462" TIME_SLOT_REF2="ts473" ANNOTATION_ID="a2893953"><ANNOTATION_VALUE>Mostly I was really into athletics and later into soccer.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts500" ANNOTATION_ID="a2893955"><ANNOTATION_VALUE>Back then I lived in the Karlsruhe area.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts500" TIME_SLOT_REF2="ts515" ANNOTATION_ID="a2893956"><ANNOTATION_VALUE>Then I moved to Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts534" ANNOTATION_ID="a2893964"><ANNOTATION_VALUE>There I fell in love.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts534" TIME_SLOT_REF2="ts541" ANNOTATION_ID="a2893966"><ANNOTATION_VALUE>Everything was going really well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts556" ANNOTATION_ID="a2893970"><ANNOTATION_VALUE>I was very focused on my sports activities in Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts556" TIME_SLOT_REF2="ts571" ANNOTATION_ID="a2893975"><ANNOTATION_VALUE>I did all kinds of sports, e.g. volleyball, soccer, and athletics.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts586" ANNOTATION_ID="a2893978"><ANNOTATION_VALUE>I was an all-round talent, so to speak.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts586" TIME_SLOT_REF2="ts601" ANNOTATION_ID="a2895031"><ANNOTATION_VALUE>I met many deaf people and this way I continued to learn sign language.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts659" ANNOTATION_ID="a2895034"><ANNOTATION_VALUE>I only started to become aware of the differences in sign language because I moved from Karlsruhe to Berlin; for example, I only knew one sign for all the days of the week.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts678" ANNOTATION_ID="a2895041"><ANNOTATION_VALUE>Where on the other hand here in Berlin, every day of the week has its own sign.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts678" TIME_SLOT_REF2="ts691" ANNOTATION_ID="a2895051"><ANNOTATION_VALUE>The people from Berlin all acted like a bunch of braggers in front of me.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts691" TIME_SLOT_REF2="ts708" ANNOTATION_ID="a2895055"><ANNOTATION_VALUE>For instance, one of them told me that he earned 5,000 Mark.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts708" TIME_SLOT_REF2="ts715" ANNOTATION_ID="a2895058"><ANNOTATION_VALUE>I was surprised and impressed.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts724" ANNOTATION_ID="a2895059"><ANNOTATION_VALUE>He was bragging about it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts724" TIME_SLOT_REF2="ts731" ANNOTATION_ID="a2895062"><ANNOTATION_VALUE>I asked him again about the high income.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts746" ANNOTATION_ID="a2895066"><ANNOTATION_VALUE>Then he asked me if I didn't get that he had made 5,000 Mark in only three months time.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts746" TIME_SLOT_REF2="ts761" ANNOTATION_ID="a2895067"><ANNOTATION_VALUE>Then I understood that he wasn't talking about his monthly income.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts761" TIME_SLOT_REF2="ts774" ANNOTATION_ID="a2895071"><ANNOTATION_VALUE>I felt like he was being overly boastful about it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts774" TIME_SLOT_REF2="ts779" ANNOTATION_ID="a2895072"><ANNOTATION_VALUE>That's just how it was in Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts779" TIME_SLOT_REF2="ts798" ANNOTATION_ID="a2895073"><ANNOTATION_VALUE>In Berlin, I learned new signs, memorized them and kept getting better and better.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts798" TIME_SLOT_REF2="ts815" ANNOTATION_ID="a2895074"><ANNOTATION_VALUE>I know my way around here and that's the reason why I wanted to start a family here.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts815" TIME_SLOT_REF2="ts826" ANNOTATION_ID="a2895075"><ANNOTATION_VALUE>I wanted to start my family in Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts826" TIME_SLOT_REF2="ts839" ANNOTATION_ID="a2895076"><ANNOTATION_VALUE>I have two hearing daughters.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts839" TIME_SLOT_REF2="ts844" ANNOTATION_ID="a2895077"><ANNOTATION_VALUE>Both are all grown up by now.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts844" TIME_SLOT_REF2="ts861" ANNOTATION_ID="a2895079"><ANNOTATION_VALUE>We took many trips together when they were younger.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts879" ANNOTATION_ID="a2895080"><ANNOTATION_VALUE>I signed to them and showed them this and that, but they sometimes spoke, sometimes signed.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts879" TIME_SLOT_REF2="ts898" ANNOTATION_ID="a2895081"><ANNOTATION_VALUE>They also stayed with their grandma and grandpa a lot.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts898" TIME_SLOT_REF2="ts905" ANNOTATION_ID="a2895082"><ANNOTATION_VALUE>That's something I regret a little.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts905" TIME_SLOT_REF2="ts916" ANNOTATION_ID="a2895083"><ANNOTATION_VALUE>I should have stayed with them more rather than letting my mother watch them all the time.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts916" TIME_SLOT_REF2="ts928" ANNOTATION_ID="a2895093"><ANNOTATION_VALUE>Their grandparents had a stronger oral influence on them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts928" TIME_SLOT_REF2="ts937" ANNOTATION_ID="a2895100"><ANNOTATION_VALUE>I regret that I wasn't with them more.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts945" ANNOTATION_ID="a2895101"><ANNOTATION_VALUE>Everything else was great.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts945" TIME_SLOT_REF2="ts968" ANNOTATION_ID="a2895105"><ANNOTATION_VALUE>My oldest daughter currently studies architecture in Cottbus.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts968" TIME_SLOT_REF2="ts991" ANNOTATION_ID="a2895116"><ANNOTATION_VALUE>My younger daughter is currently studying to become a systems informatics technician and also works in Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts991" TIME_SLOT_REF2="ts1002" ANNOTATION_ID="a2895119"><ANNOTATION_VALUE>She is content; everything is going well in her apprenticeship.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1002" TIME_SLOT_REF2="ts1023" ANNOTATION_ID="a2895120"><ANNOTATION_VALUE>When the kids moved out, my wife and I separated.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1023" TIME_SLOT_REF2="ts1036" ANNOTATION_ID="a2895123"><ANNOTATION_VALUE>My ex-wife didn't stay in Berlin, she moved to Potsdam.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1036" TIME_SLOT_REF2="ts1049" ANNOTATION_ID="a2895127"><ANNOTATION_VALUE>She's been living there for seven years now.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1049" TIME_SLOT_REF2="ts1064" ANNOTATION_ID="a2895132"><ANNOTATION_VALUE>I have a girlfriend from Hamburg now.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1064" TIME_SLOT_REF2="ts1067" ANNOTATION_ID="a2895133"><ANNOTATION_VALUE>She moved in with me.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1067" TIME_SLOT_REF2="ts1098" ANNOTATION_ID="a2895140"><ANNOTATION_VALUE>She was sent from Hamburg to #Name4 to work on a project by the German Telecom.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1098" TIME_SLOT_REF2="ts1111" ANNOTATION_ID="a2895141"><ANNOTATION_VALUE>Therefore we are still living together to this day.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1111" TIME_SLOT_REF2="ts1132" ANNOTATION_ID="a2895144"><ANNOTATION_VALUE>I focus a lot on sports here in Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1132" TIME_SLOT_REF2="ts1157" ANNOTATION_ID="a2895146"><ANNOTATION_VALUE>I used to be a top-ranking player in water polo and before that in athletics.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1157" TIME_SLOT_REF2="ts1160" ANNOTATION_ID="a2895148"><ANNOTATION_VALUE>I was very successful.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1160" TIME_SLOT_REF2="ts1169" ANNOTATION_ID="a2895149"><ANNOTATION_VALUE>Also in swimming.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1169" TIME_SLOT_REF2="ts1192" ANNOTATION_ID="a2895154"><ANNOTATION_VALUE>I also won the German Soccer Championship with the Comet club once.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1192" TIME_SLOT_REF2="ts1199" ANNOTATION_ID="a2895156"><ANNOTATION_VALUE>Now I'm older.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1199" TIME_SLOT_REF2="ts1216" ANNOTATION_ID="a2895159"><ANNOTATION_VALUE>Currently I ride my racing cycle a lot.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1216" TIME_SLOT_REF2="ts1239" ANNOTATION_ID="a2895160"><ANNOTATION_VALUE>I focus on the sport and I'm very active to this day.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1239" TIME_SLOT_REF2="ts1260" ANNOTATION_ID="a2895161"><ANNOTATION_VALUE>I now remember that I was also nominated to play for the National water polo team.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1260" TIME_SLOT_REF2="ts1289" ANNOTATION_ID="a2895801"><ANNOTATION_VALUE>At the same time I was also responsible for the German water polo department.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1289" TIME_SLOT_REF2="ts1304" ANNOTATION_ID="a2895174"><ANNOTATION_VALUE>Back then I was very engaged in both things.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1304" TIME_SLOT_REF2="ts1325" ANNOTATION_ID="a2895175"><ANNOTATION_VALUE>I participated in the Deaflypics eight times.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1325" TIME_SLOT_REF2="ts1334" ANNOTATION_ID="a3911333"><ANNOTATION_VALUE>The first time in Cologne.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1334" TIME_SLOT_REF2="ts1362" ANNOTATION_ID="a2895180"><ANNOTATION_VALUE>No, sorry, in Bulgaria, no Bucharest in Rumania.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1362" TIME_SLOT_REF2="ts1367" ANNOTATION_ID="a2895183"><ANNOTATION_VALUE>I participated first for athletics.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1367" TIME_SLOT_REF2="ts1378" ANNOTATION_ID="a2895185"><ANNOTATION_VALUE>I was also an athlete for athletics in Cologne.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1378" TIME_SLOT_REF2="ts1398" ANNOTATION_ID="a2895329"><ANNOTATION_VALUE>At my last Deaflympics in Los Angeles ’89 [sic], I played water polo.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1398" TIME_SLOT_REF2="ts1407" ANNOTATION_ID="a2895330"><ANNOTATION_VALUE>And water polo is what I stuck with.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1407" TIME_SLOT_REF2="ts1444" ANNOTATION_ID="a2895333"><ANNOTATION_VALUE>My biggest success of my whole sports career was when we won the gold metal in Australia.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1444" TIME_SLOT_REF2="ts1457" ANNOTATION_ID="a2895334"><ANNOTATION_VALUE>I'm proud of it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1457" TIME_SLOT_REF2="ts1482" ANNOTATION_ID="a2895336"><ANNOTATION_VALUE>I won the bronze medal in Taipei in Taiwan.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1482" TIME_SLOT_REF2="ts1493" ANNOTATION_ID="a2895341"><ANNOTATION_VALUE>After that I brought my sports career to an end.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1493" TIME_SLOT_REF2="ts1500" ANNOTATION_ID="a2895342"><ANNOTATION_VALUE>My water polo career as well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1500" TIME_SLOT_REF2="ts1511" ANNOTATION_ID="a2895343"><ANNOTATION_VALUE>I mean, I'm a bit older now anyway.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1511" TIME_SLOT_REF2="ts1546" ANNOTATION_ID="a2895344"><ANNOTATION_VALUE>I was 54 years old when I participated in the Games in Taipei.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1546" TIME_SLOT_REF2="ts1553" ANNOTATION_ID="a2895345"><ANNOTATION_VALUE>That was enough.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1553" TIME_SLOT_REF2="ts1570" ANNOTATION_ID="a2895348"><ANNOTATION_VALUE>But I'm still active in the sport's sector.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1570" TIME_SLOT_REF2="ts1597" ANNOTATION_ID="a2895354"><ANNOTATION_VALUE>Here in Berlin, I'm second chairman of the Deaf sports club Berlin-Brandenburg.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1597" TIME_SLOT_REF2="ts1608" ANNOTATION_ID="a2895358"><ANNOTATION_VALUE>I still work for the association.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1608" TIME_SLOT_REF2="ts1617" ANNOTATION_ID="a2895362"><ANNOTATION_VALUE>The organization goes really well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1617" TIME_SLOT_REF2="ts1646" ANNOTATION_ID="a2895363"><ANNOTATION_VALUE>For the time being, I'm substituting for the first chairman because he's currently in hospital.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1646" TIME_SLOT_REF2="ts1683" ANNOTATION_ID="a2895366"><ANNOTATION_VALUE>I'll also organize the German Deaf Sports Days 2012 in Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1683" TIME_SLOT_REF2="ts1694" ANNOTATION_ID="a3911337"><ANNOTATION_VALUE>I’m head of the organization team.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1694" TIME_SLOT_REF2="ts1703" ANNOTATION_ID="a2895369"><ANNOTATION_VALUE>I'll have to prepare that.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1703" TIME_SLOT_REF2="ts1724" ANNOTATION_ID="a2895371"><ANNOTATION_VALUE>Maybe you want to join and help me?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1728" TIME_SLOT_REF2="ts1737" ANNOTATION_ID="a2895372"><ANNOTATION_VALUE>So far, so good.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1737" TIME_SLOT_REF2="ts1742" ANNOTATION_ID="a2895373"><ANNOTATION_VALUE>So far, so good.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1744" TIME_SLOT_REF2="ts1752" ANNOTATION_ID="a2895374"><ANNOTATION_VALUE>Were you there, too?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1755" TIME_SLOT_REF2="ts1763" ANNOTATION_ID="a2895376"><ANNOTATION_VALUE>Oh, really?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1782" TIME_SLOT_REF2="ts1798" ANNOTATION_ID="a2895385"><ANNOTATION_VALUE>When did you leave the club Comet?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1819" TIME_SLOT_REF2="ts1837" ANNOTATION_ID="a2895388"><ANNOTATION_VALUE>I was there until 1981.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1843" TIME_SLOT_REF2="ts1859" ANNOTATION_ID="a2895393"><ANNOTATION_VALUE>Yes, right, he was there.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1859" TIME_SLOT_REF2="ts1872" ANNOTATION_ID="a2895394"><ANNOTATION_VALUE>I left when I won the German Championship.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1879" TIME_SLOT_REF2="ts1887" ANNOTATION_ID="a2895397"><ANNOTATION_VALUE>Yes.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1895" TIME_SLOT_REF2="ts1905" ANNOTATION_ID="a2895400"><ANNOTATION_VALUE>He has gained a lot of weight since then.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1915" TIME_SLOT_REF2="ts1935" ANNOTATION_ID="a2895405"><ANNOTATION_VALUE>Rainer Zieske was with them as well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1938" TIME_SLOT_REF2="ts1969" ANNOTATION_ID="a2895410"><ANNOTATION_VALUE>I also used to play water polo with Uwe Zieske and the others back then.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1969" TIME_SLOT_REF2="ts1984" ANNOTATION_ID="a2895412"><ANNOTATION_VALUE>We travelled and were on the road a lot.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1984" TIME_SLOT_REF2="ts1993" ANNOTATION_ID="a2895413"><ANNOTATION_VALUE>But that got less and less.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1993" TIME_SLOT_REF2="ts2010" ANNOTATION_ID="a2895440"><ANNOTATION_VALUE>That's just the way it was; the people back then were more motivated to engage in sports.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2010" TIME_SLOT_REF2="ts2019" ANNOTATION_ID="a2895439"><ANNOTATION_VALUE>That's different today.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2019" TIME_SLOT_REF2="ts2036" ANNOTATION_ID="a2895442"><ANNOTATION_VALUE>I asked a couple of people if they were interested in joining a sport.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2036" TIME_SLOT_REF2="ts2043" ANNOTATION_ID="a2895444"><ANNOTATION_VALUE>They often told me that they didn't have the time.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2043" TIME_SLOT_REF2="ts2046" ANNOTATION_ID="a2895446"><ANNOTATION_VALUE>I was surprised.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2046" TIME_SLOT_REF2="ts2087" ANNOTATION_ID="a2895450"><ANNOTATION_VALUE>Back then I didn't have time for anything else. Doing sports was everything to me.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2102" TIME_SLOT_REF2="ts2111" ANNOTATION_ID="a2895458"><ANNOTATION_VALUE>Yes, true.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2125" TIME_SLOT_REF2="ts2138" ANNOTATION_ID="a2895464"><ANNOTATION_VALUE>That was around the time that I moved to Berlin.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2138" TIME_SLOT_REF2="ts2153" ANNOTATION_ID="a2895469"><ANNOTATION_VALUE>Up until the Fall of the Berlin Wall in 1989, then there were more competitions.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2155" TIME_SLOT_REF2="ts2170" ANNOTATION_ID="a2895471"><ANNOTATION_VALUE>Yes, exactly.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2188" TIME_SLOT_REF2="ts2213" ANNOTATION_ID="a2895478"><ANNOTATION_VALUE>Exactly, we had three clubs back then. That was really good.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2213" TIME_SLOT_REF2="ts2241" ANNOTATION_ID="a2895479"><ANNOTATION_VALUE>The collaboration with the club Empor from Berlin, where water polo was concerned, was working really well.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2241" TIME_SLOT_REF2="ts2254" ANNOTATION_ID="a2895480"><ANNOTATION_VALUE>Everybody got older. It's a bit sad.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2254" TIME_SLOT_REF2="ts2273" ANNOTATION_ID="a2895481"><ANNOTATION_VALUE>Many also died and others resigned from the club.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2298" TIME_SLOT_REF2="ts2317" ANNOTATION_ID="a2895484"><ANNOTATION_VALUE>Bringing in younger people has always been an interest of mine, even back in the East.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2317" TIME_SLOT_REF2="ts2330" ANNOTATION_ID="a2895485"><ANNOTATION_VALUE>I was rarely in contact with younger people before the Fall of the Berlin Wall.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2330" TIME_SLOT_REF2="ts2335" ANNOTATION_ID="a2895486"><ANNOTATION_VALUE>That changed after the Fall of the Berlin Wall.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2335" TIME_SLOT_REF2="ts2348" ANNOTATION_ID="a2895487"><ANNOTATION_VALUE>I brought in many young people.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2348" TIME_SLOT_REF2="ts2362" ANNOTATION_ID="a2895488"><ANNOTATION_VALUE>Marco Grund was one of them.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2362" TIME_SLOT_REF2="ts2380" ANNOTATION_ID="a2895490"><ANNOTATION_VALUE>I was sort of his mentor.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2381" TIME_SLOT_REF2="ts2404" ANNOTATION_ID="a2895494"><ANNOTATION_VALUE>He brought in many young people.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2505" TIME_SLOT_REF2="ts2517" ANNOTATION_ID="a2895505"><ANNOTATION_VALUE>At the moment the number of water polo players is decreasing.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2517" TIME_SLOT_REF2="ts2526" ANNOTATION_ID="a2895506"><ANNOTATION_VALUE>There are just no younger people.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2526" TIME_SLOT_REF2="ts2547" ANNOTATION_ID="a2895507"><ANNOTATION_VALUE>There are only three water polo clubs in all of Germany – that's it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2547" TIME_SLOT_REF2="ts2565" ANNOTATION_ID="a2895508"><ANNOTATION_VALUE>There is one in Hamburg, Munich, and Berlin – that's it.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2565" TIME_SLOT_REF2="ts2582" ANNOTATION_ID="a2895510"><ANNOTATION_VALUE>And they all have trouble finding young people. It's so sad.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2585" TIME_SLOT_REF2="ts2600" ANNOTATION_ID="a2895511"><ANNOTATION_VALUE>Yes, the soccer clubs don't have any trouble.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2604" TIME_SLOT_REF2="ts2623" ANNOTATION_ID="a2895513"><ANNOTATION_VALUE>That's why I was always committed to water polo – sadly without success.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2623" TIME_SLOT_REF2="ts2634" ANNOTATION_ID="a2895514"><ANNOTATION_VALUE>Then I switched to race cycling.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2634" TIME_SLOT_REF2="ts2647" ANNOTATION_ID="a2895880"><ANNOTATION_VALUE>There, everyone was much more motivated, myself included.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2666" TIME_SLOT_REF2="ts2687" ANNOTATION_ID="a2895516"><ANNOTATION_VALUE>I get restless really fast at home.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2687" TIME_SLOT_REF2="ts2711" ANNOTATION_ID="a2895518"><ANNOTATION_VALUE>I rather go outside, out of the house.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2742" TIME_SLOT_REF2="ts2759" ANNOTATION_ID="a2895519"><ANNOTATION_VALUE>By the way: I'm a loyal employee to the company I work at.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2759" TIME_SLOT_REF2="ts2774" ANNOTATION_ID="a2895520"><ANNOTATION_VALUE>To the cigarette factory Marlboro.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2774" TIME_SLOT_REF2="ts2799" ANNOTATION_ID="a2895524"><ANNOTATION_VALUE>For 32 years, without fail.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2799" TIME_SLOT_REF2="ts2804" ANNOTATION_ID="a2895528"><ANNOTATION_VALUE>I'm very content with my job.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2804" TIME_SLOT_REF2="ts2823" ANNOTATION_ID="a2895531"><ANNOTATION_VALUE>I take care of documents, the management and the archive.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2823" TIME_SLOT_REF2="ts2832" ANNOTATION_ID="a2895534"><ANNOTATION_VALUE>There are many tasks.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2832" TIME_SLOT_REF2="ts2863" ANNOTATION_ID="a2895536"><ANNOTATION_VALUE>I work together with my work assistant. She attends meetings with me and interprets there for me, for instance.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2863" TIME_SLOT_REF2="ts2882" ANNOTATION_ID="a2895537"><ANNOTATION_VALUE>I've been working there for 32 years now.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2882" TIME_SLOT_REF2="ts2903" ANNOTATION_ID="a2895538"><ANNOTATION_VALUE>I feel really comfortable in that company and I'm rarely on sick leave.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2903" TIME_SLOT_REF2="ts2907" ANNOTATION_ID="a2895539"><ANNOTATION_VALUE>Yes, that's good.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__coarser_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_dependent_values" TIME_ALIGNABLE="false" CONSTRAINTS="Symbolic_Association"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_tokens_right_left__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__finer_granularity" TIME_ALIGNABLE="true"/><LINGUISTIC_TYPE LINGUISTIC_TYPE_ID="L_text__mouth__standard_orthography__coarser_granularity" TIME_ALIGNABLE="true"/><CONSTRAINT STEREOTYPE="Symbolic_Association" DESCRIPTION="1-1 association with a parent annotation"/></ANNOTATION_DOCUMENT>
