      "end_ms": 176560,
      "gloss_sequence": [
        "ICH1",
        "BISSCHEN2A",
        "SCHLAGEN10",
        "$GEST^",
        "SCHLECHT1*"
      ]
    },
    {
      "id": "seg_0059",
      "german_text": "In Halberstadt gab es das nicht.",
