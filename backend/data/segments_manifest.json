        "ESSEN-STADT1",
        "$INDEX1*",
        "SCHLECHT2*",
        "$INDEX1*",
        "ESSEN2*",
        "$INDEX1*",
        "HALB1A",
        "BESSER1*"
      ]
    },
    {
      "id": "seg_0062",
      "german_text": "Da ist es locker und man wird unterstützt.",
      "start_ms": 184180,
      "end_ms": 185960,
      "gloss_sequence": [
        "$INDEX1*",
        "LOCKER1",
        "UNTERSTÜTZEN4"
      ]
    },
    {
      "id": "seg_0063",
      "german_text": "Zum Beispiel sorgen sich die Lehrer um dich, wenn man Probleme hat, und sie helfen dir, unterstützen und fördern dich.",
      "start_ms": 185960,
      "end_ms": 190480,
      "gloss_sequence": [
        "BEISPIEL1*",
        "ICH1",
        "PROBLEM2A*",
        "$INDEX1",
        "DA1",
