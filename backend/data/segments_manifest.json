      "end_ms": 105180,
      "gloss_sequence": [
        "ABER1*",
        "VORTEIL2",
        "WAS1B*"
      ]
    },
    {
      "id": "seg_0036",
      "german_text": "Interessant ist, dass wir viel Mimik einsetzen und lachen.",
      "start_ms": 105180,
      "end_ms": 107780,
      "gloss_sequence": [
        "INTERESSE1A",
        "TAUB-GEHÖRLOS1A*",
        "GEBÄRDEN1E*",
        "MIMIK1",
        "LACHEN1*",
        "DA1*"
      ]
    },
    {
      "id": "seg_0037",
      "german_text": "Die Hörenden dagegen haben keine Mimik, das ist bei denen so gehaltlos.",
      "start_ms": 107780,
      "end_ms": 109620,
      "gloss_sequence": [
        "HÖREND1A*",
        "NICHT3A",
        "MIMIK1",
        "BANAL1^*",
        "$INDEX1*"
      ]
    },
    {
      "id": "seg_0038",
      "german_text": "Und was ist noch gut oder interessant am Gehörlossein, hm?",
      "start_ms": 109620,
      "end_ms": 112580,
      "gloss_sequence": [
        "INTERESSE1A",
        "WAS1A",
        "TAUB-GEHÖRLOS1A*",
        "GUT1",
        "WAS1A*",
        "$LIST1:2of2d*",
        "WAS1B*"
      ]
    },
    {
      "id": "seg_0039",
      "german_text": "Was sind noch andere Vorteile?",
      "start_ms": 112580,
      "end_ms": 114420,
      "gloss_sequence": [
        "MEHR1*",
        "VORTEIL2",
        "WAS1B*"
      ]
    },
    {
      "id": "seg_0040",
      "german_text": "Ja, wir hören nichts und haben so unsere Ruhe.",
      "start_ms": 114420,
      "end_ms": 116060,
      "gloss_sequence": [
        "OHR1*",
        "ABSCHALTEN-OHR1",
        "OHR1*",
        "RUHE1*"
      ]
    },
    {
      "id": "seg_0041",
      "german_text": "Hörende werden nervös oder bekommen Ohrenschmerzen. Die Ruhe ist ein Vorteil.",
      "start_ms": 116060,
      "end_ms": 119020,
      "gloss_sequence": [
        "$INDEX1",
        "NERVÖS1B*",
        "$GEST-OHREN-ZU1^*",
        "SCHMERZ3*",
        "VORTEIL2",
        "RUHE1",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0042",
      "german_text": "Noch mehr Vorteile sehe ich sonst nicht.",
      "start_ms": 119020,
      "end_ms": 122380,
      "gloss_sequence": [
        "$GEST^",
        "MEHR1",
        "$GEST^",
        "MEHR1*",
        "$GEST^",
        "NICHTS1A*",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0043",
      "german_text": "Schlechte Erfahrungen?",
      "start_ms": 132340,
      "end_ms": 134140,
      "gloss_sequence": [
        "SCHLECHT1*",
        "ERFAHRUNG6A*",
        "$GEST-OFF^*"
      ]
    },
    {
      "id": "seg_0044",
      "german_text": "Mein größtes Problem war mit meinen Eltern.",
      "start_ms": 136260,
      "end_ms": 140420,
      "gloss_sequence": [
        "ICH1",
        "BESONDERS1A*",
        "ICH1",
        "PROBLEM1",
        "NUR2A",
        "ELTERN7",
        "$INDEX1*"
      ]
    },
    {
      "id": "seg_0045",
      "german_text": "Denn ich wünschte mir so sehr, dass meine Eltern die Gebärdensprache können.",
      "start_ms": 140420,
      "end_ms": 143560,
      "gloss_sequence": [
        "GRUND4B",
        "$INDEX1*",
        "ICH1",
        "WÜNSCHEN1B",
        "ELTERN7",
        "KANN2B*",
        "GEBÄRDEN1E",
        "KANN1*",
        "$INDEX1*"
      ]
    },
    {
      "id": "seg_0046",
      "german_text": "Aber sie taten nichts dafür.",
      "start_ms": 143560,
      "end_ms": 144960,
      "gloss_sequence": [
        "ELTERN7",
        "MACHEN4*",
        "NICHTS1B*",
        "$INDEX1*"
      ]
    },
    {
      "id": "seg_0047",
      "german_text": "Ich gebärde/",
      "start_ms": 144960,
      "end_ms": 145400,
      "gloss_sequence": [
        "ICH1",
        "GEBÄRDEN1A*"
      ]
    },
    {
      "id": "seg_0048",
      "german_text": "Ich brauche zum Beispiel tiefgründige Unterhaltungen und den Austausch.",
      "start_ms": 145400,
      "end_ms": 148400,
      "gloss_sequence": [
        "ICH1",
        "BEISPIEL1*",
        "ICH1",
        "TIEF1*",
        "ICH1",
        "ERZÄHLEN4*",
        "TAUSCHEN1",
        "ICH1",
        "BRAUCHEN1"
      ]
    },
    {
      "id": "seg_0049",
      "german_text": "Dadurch habe ich bessere Lebenserfahrungen.",
      "start_ms": 148400,
      "end_ms": 149880,
      "gloss_sequence": [
        "ICH1",
        "KOMMA1^",
        "ICH1",
        "BESSER1*",
        "ERFAHRUNG6A*",
        "LEBEN1A*",
        "WEG2A*"
      ]
    },
    {
      "id": "seg_0050",
      "german_text": "Aber von ihnen kam nichts, da musste ich selber aktiv werden. Das war mühsam.",
      "start_ms": 149880,
      "end_ms": 151480,
      "gloss_sequence": [
        "$INDEX1*",
        "NICHTS1B*",
        "ICH1",
        "SELBST1A*",
        "AKTIV1",
        "LÄSTIG1*"
      ]
    },
    {
      "id": "seg_0051",
      "german_text": "Die gehörlosen Eltern meiner Freunde konnten mir vieles erklären, dafür bin ich ihnen sehr dankbar.",
      "start_ms": 151480,
      "end_ms": 155300,
      "gloss_sequence": [
        "ANDERS2*",
        "KONTAKT2A",
        "PERSON1*",
        "ELTERN7",
        "TAUB-GEHÖRLOS1A*",
        "ICH1",
        "ERKLÄREN1*",
        "GENUG2*",
        "WOHL1*",
        "PERSON1*",
        "GUT3*"
      ]
    },
    {
      "id": "seg_0052",
      "german_text": "Mit meinen Eltern war es leider nicht so.",
      "start_ms": 155300,
      "end_ms": 157140,
      "gloss_sequence": [
        "$INDEX1*",
        "NICHT3A",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0053",
      "german_text": "Und, na ja, es gab Probleme, über die ich mit ihnen reden wollte, aber das war schwer.",
