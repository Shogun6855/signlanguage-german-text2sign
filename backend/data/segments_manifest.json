        "ICH1*",
        "GUT1*",
        "LEBEN4",
        "GUT3*",
        "ZUSAMMEN1A*",
        "$GEST-OFF^"
      ]
    },
    {
      "id": "seg_0005",
      "german_text": "Aber das ist ja klar.",
      "start_ms": 11180,
      "end_ms": 12340,
      "gloss_sequence": [
        "KLAR1A*",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0006",
      "german_text": "Dann ist Alleinsein nicht schlimm.",
      "start_ms": 12340,
      "end_ms": 13500,
      "gloss_sequence": [
        "ALLEIN1C",
        "SCHLIMM3C*",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0007",
      "german_text": "Als ich damals in den Kindergarten kam, wusste ich noch nichts.",
      "start_ms": 14420,
      "end_ms": 18700,
      "gloss_sequence": [
        "ICH1",
        "UNGEFÄHR1^",
        "FRÜHER1",
        "ANFANG1A*",
        "KINDERGARTEN1A",
        "BEREICH1A*",
        "ICH1",
        "$GEST-OFF^*"
      ]
    },
    {
      "id": "seg_0008",
      "german_text": "Ich spielte mit hörenden Kindern und kann mich nicht an Unterschiede zwischen Hörenden und Gehörlosen erinnern.",
      "start_ms": 18700,
      "end_ms": 22460,
      "gloss_sequence": [
        "ICH1",
        "HÖREND1A*",
