      "gloss_sequence": [
        "SPÄTER7*",
        "BIS1",
        "JETZT1",
        "$GEST-SKEPTISCH1^",
        "SCHON1A",
        "JAHR1B*",
        "SCHÖN1A",
        "LIEGEN-BEIN1A^"
      ]
    },
    {
      "id": "seg_0018",
      "german_text": "Den meisten Kontakt hatte ich mit einem, der durch und durch gehörlos ist, weil er der Sohn von gehörlosen Eltern ist.",
      "start_ms": 48540,
      "end_ms": 54680,
      "gloss_sequence": [
        "KONTAKT2B",
        "ICH1",
        "MEISTENS1A*",
        "ICH1",
        "PERSON1",
        "TAUB-GEHÖRLOS1A*",
        "ECHT1",
        "ELTERN1A",
        "PERSON1*",
        "$INDEX1*",
        "SOHN1",
        "TAUB-GEHÖRLOS1A*",
        "PERSON1*",
        "$GEST^",
        "LASSEN1^*"
      ]
    },
    {
      "id": "seg_0019",
      "german_text": "Wir sind zusammen aufgewachsen, bis zu seiner Entlassung als Geselle waren wir immer zusammen, aber jetzt gehen wir jeweils unseren eigenen Lebensweg.",
      "start_ms": 54680,
      "end_ms": 60140,
      "gloss_sequence": [
        "ICH1",
        "MEHR1*",
        "ZUSAMMEN1A*",
        "AUFWACHSEN1A*",
        "ABLAUF1^*",
        "BIS1*",
        "$INDEX1*",
        "GESELLE2*",
        "WEG-ENTFERNEN1C",
        "ANDERS2",
        "AB1C*",
        "ICH1",
        "ANDERS2",
        "LEBEN1C",
        "WEG2A*",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0020",
      "german_text": "Na ja, gehörlos zu sein hat so seine Nachteile.",
      "start_ms": 66140,
      "end_ms": 70100,
      "gloss_sequence": [
        "$GEST-ÜBERLEGEN1^",
        "$GEST-ÜBERLEGEN1^",
        "$GEST-ÜBERLEGEN1^",
        "TAUB-GEHÖRLOS1A",
        "FÜR1",
        "NACHTEIL3",
        "GEBÄRDEN1A*"
      ]
    },
    {
      "id": "seg_0021",
      "german_text": "Ich kann die Welt nicht so erleben wie ein Hörender und mit anderen Hörenden kommunizieren. Da stoße ich immer auf Barrieren.",
      "start_ms": 70100,
      "end_ms": 76160,
      "gloss_sequence": [
        "ICH1",
        "$GEST^",
        "KANN2A",
        "NICHT3A*",
        "WELT1",
        "LEBEN4*",
        "BEISPIEL1*",
        "LEUTE2*",
        "HÖREND1A*",
        "ICH1",
        "KOMMUNIKATION1A*",
        "KANN1*",
        "BARRIERE1*",
        "$GEST-OFF^"
      ]
    },
    {
      "id": "seg_0022",
      "german_text": "Und wenn ich mir zum Beispiel einen Film oder Infos anschauen will, sind die meist ohne Untertitel.",
      "start_ms": 76160,
      "end_ms": 79600,
      "gloss_sequence": [
        "UND2A",
        "$GEST-ÜBERLEGEN1^*",
        "KANN1*",
        "BEISPIEL1*",
        "NORMAL1*",
        "FILM1",
        "INFORMATION1*",
        "$INDEX1*",
        "UNTERTITEL1*",
        "KEIN1*",
        "$INDEX1"
      ]
    },
    {
      "id": "seg_0023",
      "german_text": "Das Gesprochene ist mühsam.",
      "start_ms": 79600,
      "end_ms": 81300,
      "gloss_sequence": [
        "SPRECHEN5A",
        "$INDEX1",
        "MÜHE1"
      ]
    },
    {
      "id": "seg_0024",
      "german_text": "Oder ein anderes Beispiel: in der Disco gibt es viele hübsche Frauen, die ich gerne kennengelernt hätte.",
      "start_ms": 81300,
      "end_ms": 84840,
      "gloss_sequence": [
        "ODER4B*",
        "ANDERS2*",
        "ICH1",
        "DISCO2",
        "ICH1",
        "WOLLEN1B",
        "HÖREND1A*",
        "ICH1",
        "KENNENLERNEN1*",
        "MÄDCHEN2C*",
        "HÜBSCH1A"
      ]
    },
    {
      "id": "seg_0025",
      "german_text": "Ich bedauere, dass ich sie mir nicht angeln kann, weil die Kommunikation ein Problem ist.",
      "start_ms": 84840,
      "end_ms": 86900,
      "gloss_sequence": [
        "BEDAUERN1*",
        "ICH1",
        "ANGELN-PERSON1*",
        "$INDEX1",
        "KOMMUNIKATION1A*",
        "PROBLEM1",
        "KOMMUNIKATIONSDEFIZIT1"
      ]
    },
    {
      "id": "seg_0026",
      "german_text": "Das ist mühsam.",
      "start_ms": 86900,
      "end_ms": 87460,
      "gloss_sequence": [
        "MÜHE1"
      ]
    },
    {
      "id": "seg_0027",
      "german_text": "Oder/",
      "start_ms": 87460,
      "end_ms": 88280,
      "gloss_sequence": [
        "ODER2*"
      ]
    },
    {
      "id": "seg_0028",
      "german_text": "Ach, es gibt viele weitere Nachteile.",
      "start_ms": 88280,
      "end_ms": 91500,
      "gloss_sequence": [
        "$GEST^",
        "VIEL1A*",
        "TEXT3^",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0029",
      "german_text": "Oh, und ein Nachteil ist auch, dass ein Hörender es typischerweise mit dem Lernen viel leichter hat.",
      "start_ms": 92140,
      "end_ms": 97020,
      "gloss_sequence": [
        "UND2A*",
        "UNGEFÄHR1^",
        "NACHTEIL3",
        "AUCH1A*",
        "$INDEX1*",
        "HÖREND1A",
        "STARK2A*",
        "TYPISCH1*",
        "$INDEX1*",
        "MEISTENS1B",
        "WAHRNEHMEN-AUGE1A^",
        "KANN2A",
        "LEICHT1*"
      ]
    },
    {
      "id": "seg_0030",
      "german_text": "Er braucht nur zuzuhören und muss nicht noch viel lernen/",
      "start_ms": 97020,
      "end_ms": 98040,
      "gloss_sequence": [
        "LERNEN1*",
        "SELBST1A*",
        "BRAUCHEN1*",
        "LERNEN1*"
      ]
    },
    {
      "id": "seg_0031",
      "german_text": "Ich, als Gehörloser, muss viel lesen und verstehe viele Wörter nicht.",
      "start_ms": 98040,
      "end_ms": 100680,
      "gloss_sequence": [
        "ICH1",
        "TAUB-GEHÖRLOS1A*",
        "MUSS1*",
        "ICH1",
        "LESEN1C*",
        "SEHR7^*",
        "ANSTRENGEND5",
        "WORT3",
        "KENNEN1B*"
      ]
    },
    {
      "id": "seg_0032",
      "german_text": "Das macht mir zu schaffen.",
      "start_ms": 100680,
      "end_ms": 100960,
      "gloss_sequence": [
        "MÜHE1"
      ]
    },
    {
      "id": "seg_0033",
      "german_text": "Das Lesen ist echt mühsam.",
      "start_ms": 100960,
      "end_ms": 102240,
      "gloss_sequence": [
        "LESEN1C*",
        "ZUNGE1^*",
        "MÜHE1"
      ]
    },
    {
      "id": "seg_0034",
      "german_text": "Das ist der typische Nachteil für einen Gehörlosen.",
      "start_ms": 102240,
      "end_ms": 103400,
      "gloss_sequence": [
        "NACHTEIL3",
        "TAUB-GEHÖRLOS1A*",
        "SO1A"
      ]
    },
    {
      "id": "seg_0035",
      "german_text": "Aber was wäre ein Vorteil?",
