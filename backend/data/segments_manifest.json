      "gloss_sequence": [
        "GUT1",
        "WAS-BEDEUTET1*",
        "GUT1",
        "ICH1*",
        "IRGENDWAS1*",
        "$GEST-ICH-WEISS-NICHT1^"
      ]
    },
    {
