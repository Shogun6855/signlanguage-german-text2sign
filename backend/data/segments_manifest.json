      "end_ms": 179880,
      "gloss_sequence": [
        "HALB1A",
        "STADT2",
        "NICHTS1B"
      ]
    },
    {
      "id": "seg_0060",
      "german_text": "Da waren alle viel netter und freundlicher.",
      "start_ms": 179880,
      "end_ms": 181660,
      "gloss_sequence": [
        "FREUNDLICH3*",
        "LIEB1A",
        "GEBÄRDEN1E*"
      ]
    },
    {
      "id": "seg_0061",
      "german_text": "Aber in Essen war es richtig schlecht, also im Vergleich zu Essen war es in Halberstadt einfach besser.",
      "start_ms": 181660,
      "end_ms": 184180,
      "gloss_sequence": [
