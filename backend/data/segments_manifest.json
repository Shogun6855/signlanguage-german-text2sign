        "DAMALS1*",
        "NICHTS1B",
        "ERINNERUNG2*",
        "NICHTS1B*"
      ]
    },
    {
      "id": "seg_0009",
      "german_text": "So ging es weiter, bis ich in den Kindergarten in Halberstadt kam.",
      "start_ms": 22460,
      "end_ms": 25500,
      "gloss_sequence": [
        "SPÄTER7*",
        "GENAU4^",
        "ICH1",
        "$INDEX1*",
        "HALB1B",
        "STADT2",
        "KINDERGARTEN1A*",
        "EINTRETEN1A*"
      ]
    },
    {
      "id": "seg_0010",
      "german_text": "Das war interessant, ich war fasziniert von den Gebärden und wir spielten zusammen, das war klasse.",
      "start_ms": 25500,
      "end_ms": 28580,
      "gloss_sequence": [
        "BEREICH1A*",
        "INTERESSE1A",
        "MERKWÜRDIG1^*",
        "GEBÄRDEN1A*",
        "FASZINIEREND2*",
        "GEBÄRDEN1A*",
        "SPIELEN2*",
        "BEREICH1A*",
        "INTERESSE1A*",
        "$GEST-OFF^"
      ]
    },
    {
      "id": "seg_0011",
      "german_text": "Ja, wir haben gespielt.",
      "start_ms": 28580,
      "end_ms": 30160,
      "gloss_sequence": [
        "SPIELEN2*",
        "BEREICH1A*",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0012",
      "german_text": "Ich habe schöne Erinnerungen an früher.",
      "start_ms": 30160,
      "end_ms": 31140,
      "gloss_sequence": [
        "FRÜHER1*",
        "SCHÖN1A",
        "ERINNERUNG2*"
      ]
    },
    {
      "id": "seg_0013",
      "german_text": "Wir haben gespielt und Quatsch gemacht, verschiedenes ausgeheckt, bis/",
      "start_ms": 31140,
      "end_ms": 35380,
      "gloss_sequence": [
        "SPIELEN2*",
        "SITZEN1A^*",
        "BEREICH1A*",
        "QUATSCH1*",
        "SITZEN1A^*",
        "VERSCHIEDEN1*",
        "UND2A",
        "MERKWÜRDIG1^*",
        "BIS1*"
      ]
    },
    {
      "id": "seg_0014",
      "german_text": "Ja, die Zeit verging da so schnell, schon war ich eingeschult.",
      "start_ms": 35380,
      "end_ms": 38000,
      "gloss_sequence": [
        "ICH1",
        "SCHNELL3A",
        "STUNDENLANG1",
        "FERTIG1A",
        "ICH1",
        "ANFANG1A",
        "SCHULE1A*",
        "EINSCHULEN1",
        "MERKWÜRDIG1^*"
      ]
    },
    {
      "id": "seg_0015",
      "german_text": "Ich musste dort zum Mathe- und Deutschunterricht und so weiter.",
      "start_ms": 38000,
      "end_ms": 40180,
      "gloss_sequence": [
        "ICH1",
        "UNTERRICHTEN1*",
        "MUSS1*",
        "RECHNEN1*",
        "DEUTSCH1",
        "UND-SO-WEITER4*"
      ]
    },
    {
      "id": "seg_0016",
      "german_text": "Ich war im Unterricht ganz gut, aber weil ich meistens mit den anderen zusammen spielte, verpasste ich einiges.",
      "start_ms": 40180,
      "end_ms": 44100,
      "gloss_sequence": [
        "ICH1",
        "UNTERRICHTEN1*",
        "GUT3*",
        "ICH1*",
        "UNTERRICHTEN1*",
        "ETWAS-NICHT-MITBEKOMMEN1^*",
        "ICH1",
        "MEISTENS1B*",
        "SPIELEN2*",
        "ZUSAMMEN1A",
        "ETWAS-NICHT-MITBEKOMMEN1^*",
        "UNTERSCHIED3^*"
      ]
    },
    {
      "id": "seg_0017",
      "german_text": "So ging es ungefähr 10 Jahre lang, das war schön.",
      "start_ms": 44100,
