        "VERSTEHEN1*",
        "NICHTS1B*",
        "MÜHE1",
        "$GEST^"
      ]
    },
    {
      "id": "seg_0055",
      "german_text": "In der Schule in Essen war das auch ein Problem, wir konnten schlecht mit den Lehrern kommunizieren.",
