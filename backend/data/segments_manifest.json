        "ICH1",
        "SCHLECHT2",
        "NOTE2",
        "MÜHE1",
        "$LIST-ZUSAMMEN3:3-5of5"
      ]
    },
    {
      "id": "seg_0057",
      "german_text": "Es passierten viele schlimme Dinge. Ich war zum Beispiel in einer Gruppe, die schlimme Kritik ausgeteilt hat.",
      "start_ms": 172360,
      "end_ms": 174420,
      "gloss_sequence": [
