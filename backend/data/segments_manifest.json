        "BESCHEID1A*",
        "$INDEX1*",
        "SCHWER1B^*",
        "LÄSTIG1*",
        "AUF-PERSON1*",
        "$GEST-OFF^*"
      ]
    },
    {
      "id": "seg_0054",
      "german_text": "Sie verstanden mich nicht, das war sehr schwer für mich.",
