  "num_segments": 105,
  "segments": [
    {
      "id": "seg_0001",
      "german_text": "Wie mein Leben aussieht?",
      "start_ms": 240,
      "end_ms": 2160,
      "gloss_sequence": [
        "SEHEN1*",
        "SELBST1A*",
        "LEBEN1A*",
        "SEHEN1",
        "$GEST-OFF^"
      ]
    },
    {
      "id": "seg_0002",
      "german_text": "Na ja, ich bin als Gehörloser aufgewachsen.",
