      "id": "seg_0094",
      "german_text": "Ich lernte ihn durch meinen Umzug nach Essen kennen.",
      "start_ms": 299260,
      "end_ms": 300700,
      "gloss_sequence": [
        "ICH1*",
        "DURCH2A",
        "ICH1",
        "ESSEN2*",
        "UMZIEHEN1*"
      ]
    },
