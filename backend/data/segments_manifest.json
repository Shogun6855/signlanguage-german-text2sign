        "SCHULE1A*",
        "$INDEX1*",
        "LEHRER2*",
        "SCHLECHT2",
        "KOMMUNIKATION1A*",
        "PROBLEM1"
      ]
    },
    {
      "id": "seg_0056",
      "german_text": "Es gab Kommunikationsprobleme und Mobbing und ich habe mich geärgert, dass ich schlechte Noten bekommen habe, das war schwierig.",
      "start_ms": 168160,
      "end_ms": 172360,
      "gloss_sequence": [
