      "end_ms": 4120,
      "gloss_sequence": [
        "AUFWACHSEN1A*",
        "ICH1",
        "TAUB-GEHÖRLOS1A*"
      ]
    },
    {
      "id": "seg_0003",
      "german_text": "Ich habe eher das Gefühl, wenn ich mir vorstelle, dass ich allein bin, dann wäre ich einsam.",
