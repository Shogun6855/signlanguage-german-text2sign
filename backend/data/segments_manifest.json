      "end_ms": 205680,
      "gloss_sequence": [
        "ICH1",
        "ACHTUNG1A^*",
        "GUT1"
      ]
    },
    {
      "id": "seg_0068",
      "german_text": "In Essen konnte ich mehr Gehörlose kennenlernen.",
