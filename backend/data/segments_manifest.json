        "SCHLIMM3B",
        "$INDEX1*",
        "GRUPPE1A*",
        "KRITISIEREN1A*",
        "SCHLIMM3A*"
      ]
    },
    {
      "id": "seg_0058",
      "german_text": "Ich habe mich auch ein bisschen geprügelt. Ach, das war schlecht.",
