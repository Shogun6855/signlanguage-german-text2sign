        "GEFÜHL3",
        "VORSTELLUNG1A*",
        "ICH1*",
        "ALLEIN1C*",
        "ICH1",
        "BEREICH1A*",
        "GEFÜHL3*",
        "VORSTELLUNG1A"
      ]
    },
    {
      "id": "seg_0004",
      "german_text": "Da treffe ich lieber viele Gehörlose und mache mit denen was, dann ist mein Leben schön.",
